/-- n000004: For a field `F`, an irreducible and separable polynomial `P`, and `k >= 1`, let
`R = F[X]/(P^k)` and `K = F[X]/(P)` with quotient map `pi`; there is an `F`-algebra section
`s : K -> R` such that `pi` composed with `s` is the identity on `K`. -/
theorem exists_alg_section_quotient_map
    {F : Type*} [Field F] {P : Polynomial F} (hPirr : Irreducible P) (hPsep : P.Separable)
    {k : Nat} (hk : 1 <= k) :
    let I : Ideal (Polynomial F) := Ideal.span ({P ^ k} : Set (Polynomial F))
    let J : Ideal (Polynomial F) := Ideal.span ({P} : Set (Polynomial F))
    let R := (Polynomial F) ⧸ I
    let K := (Polynomial F) ⧸ J
    forall pi : AlgHom F R K,
      (forall x : Polynomial F, pi (Ideal.Quotient.mk I x) = Ideal.Quotient.mk J x) ->
      Exists fun s : AlgHom F K R => AlgHom.comp pi s = AlgHom.id F K := by
  classical
  dsimp
  intro pi hpi
  let I : Ideal (Polynomial F) := Ideal.span ({P ^ k} : Set (Polynomial F))
  let J : Ideal (Polynomial F) := Ideal.span ({P} : Set (Polynomial F))
  let R := (Polynomial F) ⧸ I
  let K := (Polynomial F) ⧸ J
  have hIJ : I ≤ J := ideal_span_pow_le_span P hk
  let pi0 : AlgHom F R K :=
    Ideal.Quotient.liftₐ I (Ideal.Quotient.mkₐ F J)
      (helperFor_n000004_mkₐ_eq_zero_of_mem (I := I) (J := J) hIJ)
  have hpi_eq :
      pi = pi0 :=
    helperFor_n000004_pi_eq_pi0 (I := I) (J := J) hIJ pi hpi
  by_cases hk1 : k = 1
  · subst hk1
    have hIeq : I = J := by
      simp [I, J, pow_one]
    have hJI : J ≤ I := by
      simpa [hIeq] using (le_rfl : I ≤ I)
    let s : AlgHom F K R :=
      Ideal.Quotient.liftₐ J (Ideal.Quotient.mkₐ F I)
        (helperFor_n000004_mkₐ_eq_zero_of_mem (I := J) (J := I) hJI)
    have hs_comp :
        s.comp (Ideal.Quotient.mkₐ F J) = Ideal.Quotient.mkₐ F I := by
      simpa [s] using
        (Ideal.Quotient.liftₐ_comp (I := J) (f := Ideal.Quotient.mkₐ F I)
          (helperFor_n000004_mkₐ_eq_zero_of_mem (I := J) (J := I) hJI))
    have hpi0_comp :
        pi0.comp (Ideal.Quotient.mkₐ F I) = Ideal.Quotient.mkₐ F J := by
      simpa [pi0] using
        (Ideal.Quotient.liftₐ_comp (I := I) (f := Ideal.Quotient.mkₐ F J)
          (helperFor_n000004_mkₐ_eq_zero_of_mem (I := I) (J := J) hIJ))
    have hpi0_comp_s : AlgHom.comp pi0 s = AlgHom.id F K := by
      apply (Ideal.Quotient.algHom_ext (I := J) (R₁ := F))
      calc
        (pi0.comp s).comp (Ideal.Quotient.mkₐ F J) =
            pi0.comp (s.comp (Ideal.Quotient.mkₐ F J)) := by
              simp [AlgHom.comp_assoc]
        _ = pi0.comp (Ideal.Quotient.mkₐ F I) := by
              simpa [hs_comp]
        _ = Ideal.Quotient.mkₐ F J := by
              simpa [hpi0_comp]
        _ = (AlgHom.id F K).comp (Ideal.Quotient.mkₐ F J) := by
              simp
    refine ⟨s, ?_⟩
    simpa [hpi_eq] using hpi0_comp_s
  · have hk2 : 2 <= k := by
      have hklt : 1 < k := lt_of_le_of_ne hk (Ne.symm hk1)
      simpa using hklt
    have hsep : IsCoprime P (Polynomial.derivative P) := by
      simpa [Polynomial.separable_def] using hPsep
    have hy :
        let R := helperFor_n000004_polynomialPowerQuotient F P k
        let Pbar : R := helperFor_n000004_polynomialPowerQuotientP F P k
        let x : R := helperFor_n000004_polynomialPowerQuotientX F P k
        ∃ y : R,
          y - x ∈ Ideal.span ({Pbar} : Set R) ∧
          Polynomial.aeval y P = 0 :=
      helperFor_n000004_exists_lifted_root (P := P) (k := k) hk2 hsep
    dsimp at hy
    rcases hy with ⟨y, hyx, hyP⟩
    let Pbar : R := helperFor_n000004_polynomialPowerQuotientP F P k
    let x : R := helperFor_n000004_polynomialPowerQuotientX F P k
    let M : Ideal R := Ideal.span ({Pbar} : Set R)
    have hy_ideal :
        ∀ q : Polynomial F, q ∈ J → (Polynomial.aeval y q : R) = 0 :=
      helperFor_n000004_aeval_mem_span_P_eq_zero (P := P) (y := y) hyP
    let s : AlgHom F K R := Ideal.Quotient.liftₐ J (Polynomial.aeval y) hy_ideal
    have hs_comp :
        s.comp (Ideal.Quotient.mkₐ F J) = Polynomial.aeval y := by
      simpa [s] using
        (Ideal.Quotient.liftₐ_comp (I := J) (f := Polynomial.aeval y) hy_ideal)
    have hpi0_comp :
        pi0.comp (Ideal.Quotient.mkₐ F I) = Ideal.Quotient.mkₐ F J := by
      simpa [pi0] using
        (Ideal.Quotient.liftₐ_comp (I := I) (f := Ideal.Quotient.mkₐ F J)
          (helperFor_n000004_mkₐ_eq_zero_of_mem (I := I) (J := J) hIJ))
    have hpi0x :
        pi0 x = Ideal.Quotient.mk J Polynomial.X := by
      have hpi0x' :=
        congrArg (fun f : Polynomial F →ₐ[F] K => f Polynomial.X) hpi0_comp
      simpa [x, Ideal.Quotient.mkₐ_eq_mk] using hpi0x'
    have hPmem : P ∈ J := Ideal.subset_span (by simp)
    have hmkP : Ideal.Quotient.mk J P = 0 := (Ideal.Quotient.eq_zero_iff_mem).2 hPmem
    have hpi0P :
        pi0 (Ideal.Quotient.mk I P) = Ideal.Quotient.mk J P := by
      have hpi0P' :=
        congrArg (fun f : Polynomial F →ₐ[F] K => f P) hpi0_comp
      simpa [Ideal.Quotient.mkₐ_eq_mk] using hpi0P'
    have hpi0_Pbar : pi0 Pbar = 0 := by
      have hpi0P0 : pi0 (Ideal.Quotient.mk I P) = 0 := by
        simpa [hmkP] using hpi0P
      simpa [Pbar, helperFor_n000004_polynomialPowerQuotientP] using hpi0P0
    rcases Ideal.mem_span_singleton'.1 hyx with ⟨a, ha⟩
    have ha' : y - x = a * Pbar := by
      simpa [Pbar] using ha.symm
    have hpi0_sub : pi0 y - pi0 x = pi0 a * pi0 Pbar := by
      calc
        pi0 y - pi0 x = pi0 (y - x) := by
          symm
          simpa using (map_sub pi0 y x)
        _ = pi0 (a * Pbar) := by
          exact congrArg pi0 ha'
        _ = pi0 a * pi0 Pbar := by
          simpa using map_mul pi0 a Pbar
    have hpi0_sub_zero : pi0 y - pi0 x = 0 := by
      simpa [hpi0_Pbar] using hpi0_sub
    have hpi0y : pi0 y = Ideal.Quotient.mk J Polynomial.X := by
      have hpi0yx : pi0 y = pi0 x := sub_eq_zero.mp hpi0_sub_zero
      simpa [hpi0x] using hpi0yx
    have hpi0_aeval : pi0.comp (Polynomial.aeval y) = Ideal.Quotient.mkₐ F J := by
      apply AlgHom.ext
      intro f
      calc
        pi0 (Polynomial.aeval y f) = Polynomial.aeval (pi0 y) f := by
          simpa using (Polynomial.aeval_algHom_apply pi0 y f).symm
        _ = Polynomial.aeval (Ideal.Quotient.mk J Polynomial.X) f := by
          exact congrArg (fun t => Polynomial.aeval t f) hpi0y
        _ = Ideal.Quotient.mk J f := by
          have h :=
            (Polynomial.eval₂_algebraMap_X (p := f) (f := Ideal.Quotient.mkₐ F J))
          simpa [Polynomial.aeval_def, Ideal.Quotient.mkₐ_eq_mk] using h
    have hpi0_comp_s : AlgHom.comp pi0 s = AlgHom.id F K := by
      apply (Ideal.Quotient.algHom_ext (I := J) (R₁ := F))
      calc
        (pi0.comp s).comp (Ideal.Quotient.mkₐ F J) =
            pi0.comp (s.comp (Ideal.Quotient.mkₐ F J)) := by
              simp [AlgHom.comp_assoc]
        _ = pi0.comp (Polynomial.aeval y) := by
              simpa [hs_comp]
        _ = Ideal.Quotient.mkₐ F J := by
              simpa [hpi0_aeval]
        _ = (AlgHom.id F K).comp (Ideal.Quotient.mkₐ F J) := by
              simp
    refine ⟨s, ?_⟩
    simpa [hpi_eq] using hpi0_comp_s

end
