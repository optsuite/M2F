import Mathlib

universe u

/--
Let \( E \) be a commutative ring, \( F \) be an \( E \)-algebra, then we say \( F \) is
a radical extension over \( E \), if \( F \) is generated by a single element \( x \in F \) over \( E \)
such that \( x ^ n - e = 0 \) for some \( e \in E \).
-/
def IsRadicalExtension (E F : Type u) [CommRing E] [CommRing F] [Algebra E F] : Prop :=
    ∃ (x : F), Algebra.adjoin E {x} = ⊤ ∧ (∃ (n : ℕ) (e : E), n ≥ 1 ∧ x ^ n - (algebraMap E F) e = 0)

/--
An algebra is said to be a radical tower over the base ring if it can be written as
composition of radical extensions.
-/
inductive IsRadicalTower : ∀ (E : Type u) (F : Type u) [CommRing E] [CommRing F] [Algebra E F], Prop
  | of_isRadicalExtension {E F : Type u} [CommRing E] [CommRing F] [Algebra E F] :
      IsRadicalExtension E F →
        Module.rank E F ≤ (2 : Cardinal.{u}) →
          IsRadicalTower E F
  | of_composition {E F : Type u} [CommRing E] [CommRing F] [Algebra E F] (F' : Subalgebra E F) :
      IsRadicalExtension F' F →
        IsRadicalTower E F' →
          Module.rank E F ≤ (2 : Cardinal.{u}) →
            IsRadicalTower E F

/-- An `E`-algebra hom between fields is injective, hence gives a rank inequality. -/
lemma algHom_rank_le {E K L : Type u} [CommRing E] [Field K] [Field L]
    [Algebra E K] [Algebra E L] (f : K →ₐ[E] L) :
    Module.rank E K ≤ Module.rank E L := by
  have hf : Function.Injective f := by
    intro x y hxy
    exact (RingHom.injective f.toRingHom) hxy
  simpa using (LinearMap.rank_le_of_injective f.toLinearMap hf)

/-- Transport the Galois property along the field range of an algebra hom. -/
lemma AlgHom.fieldRange_isGalois {E K L : Type*} [Field E] [Field K] [Field L]
    [Algebra E K] [Algebra E L] [IsGalois E K] (f : K →ₐ[E] L) :
    IsGalois E f.fieldRange := by
  simpa using (IsGalois.of_algEquiv (f := AlgEquiv.ofInjectiveField f))

/-- The field range of an algebra hom has the same `E`-finrank as the domain. -/
lemma AlgHom.finrank_fieldRange_eq {E K L : Type*} [Field E] [Field K] [Field L]
    [Algebra E K] [Algebra E L] [FiniteDimensional E K] (f : K →ₐ[E] L) :
    Module.finrank E f.fieldRange = Module.finrank E K := by
  classical
  have h_eq : Module.finrank E f.fieldRange.toSubalgebra = Module.finrank E K := by
    simpa [AlgHom.fieldRange_toSubalgebra] using
      (AlgEquiv.ofInjectiveField f).toLinearEquiv.finrank_eq.symm
  simpa using h_eq

/-- A nontrivial intermediate field has `E`-finrank different from `1`. -/
lemma IntermediateField.finrank_ne_one_of_ne_bot {E K : Type*} [Field E] [Field K]
    [Algebra E K] (L : IntermediateField E K) [FiniteDimensional E L] (hL : L ≠ ⊥) :
    Module.finrank E L ≠ 1 := by
  intro h_one
  apply hL
  exact (IntermediateField.finrank_eq_one_iff (F := E) (E := K) (K := L)).1 h_one

/-- An odd natural number different from `1` is at least `3`. -/
lemma odd_ne_one_three_le {n : ℕ} (h_odd : Odd n) (h_ne_one : n ≠ 1) : 3 ≤ n := by
  rcases h_odd with ⟨k, hk⟩
  by_cases hk0 : k = 0
  · subst hk0
    have : (2 * 0 + 1 : ℕ) = 1 := by simp
    exact (h_ne_one (hk.trans this)).elim
  · have hk_pos : 1 ≤ k := Nat.succ_le_iff.mpr (Nat.pos_of_ne_zero hk0)
    have h_two_le : 2 ≤ 2 * k := by
      simpa [one_mul] using (Nat.mul_le_mul_left 2 hk_pos)
    have h_three_le : 3 ≤ 2 * k + 1 := Nat.succ_le_succ h_two_le
    simpa [hk] using h_three_le

/-- A radical extension is module-finite over its base ring. -/
lemma IsRadicalExtension.moduleFinite {E F : Type u} [CommRing E] [CommRing F] [Algebra E F]
    (h : IsRadicalExtension E F) : Module.Finite E F := by
  rcases h with ⟨x, h_adjoin, n, e, hn, hxe⟩
  have hx_pow_eq : x ^ n = algebraMap E F e := by
    exact (sub_eq_zero.mp hxe)
  have hx_pow : IsIntegral E (x ^ n) := by
    simpa [hx_pow_eq] using (isIntegral_algebraMap (R := E) (A := F) (x := e))
  have hn' : 0 < n := by
    exact Nat.succ_le_iff.mp hn
  have hx_int : IsIntegral E x :=
    IsIntegral.of_pow (R := E) (B := F) (x := x) (n := n) hn' hx_pow
  have hfinite_adjoin : Module.Finite E (Algebra.adjoin E {x}) :=
    Algebra.finite_adjoin_simple_of_isIntegral (R := E) (B := F) (x := x) hx_int
  have hfinite_top : Module.Finite E (⊤ : Subalgebra E F) := by
    rw [← h_adjoin]
    exact hfinite_adjoin
  haveI : Module.Finite E (⊤ : Subalgebra E F) := hfinite_top
  exact
    Module.Finite.equiv
      (Subalgebra.topEquiv : (⊤ : Subalgebra E F) ≃ₐ[E] F).toLinearEquiv

/-- A radical tower is module-finite over its base ring. -/
lemma IsRadicalTower.moduleFinite {E F : Type u} [CommRing E] [CommRing F] [Algebra E F]
    (h : IsRadicalTower E F) : Module.Finite E F := by
  classical
  refine
    IsRadicalTower.rec (E := E)
      (motive := fun F _ _ _ _ => Module.Finite E F) ?_ ?_ h
  · intro F _ _ _ h_ext _
    exact IsRadicalExtension.moduleFinite h_ext
  · intro F _ _ _ F' h_ext _ _ ih
    have hfinite_F' : Module.Finite F' F := IsRadicalExtension.moduleFinite h_ext
    haveI : Module.Finite E F' := ih
    haveI : Module.Finite F' F := hfinite_F'
    exact Module.Finite.trans (R := E) (A := F') (M := F)

/-- Missing bound: a radical tower over a field should have `E`-finrank at most `2`. -/
lemma IsRadicalTower.finrank_le_two_of_field {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] [FiniteDimensional E K'] (h : IsRadicalTower E K') :
    Module.finrank E K' ≤ 2 := by
  classical
  cases h with
  | of_isRadicalExtension _ h_rank_le =>
      have h_rank_le' : Module.rank E K' ≤ (2 : Cardinal) := by
        simpa using h_rank_le
      have h_card : (Module.finrank E K' : Cardinal) ≤ 2 := by
        calc
          (Module.finrank E K' : Cardinal) = Module.rank E K' := by
            simp
          _ ≤ 2 := h_rank_le'
      exact (Nat.cast_le.mp h_card)
  | of_composition _ _ _ h_rank_le =>
      have h_rank_le' : Module.rank E K' ≤ (2 : Cardinal) := by
        simpa using h_rank_le
      have h_card : (Module.finrank E K' : Cardinal) ≤ 2 := by
        calc
          (Module.finrank E K' : Cardinal) = Module.rank E K' := by
            simp
          _ ≤ 2 := h_rank_le'
      exact (Nat.cast_le.mp h_card)

/-- Missing bound: a radical tower over a field cannot have degree at least `3`. -/
lemma IsRadicalTower.finrank_three_le_false_of_field {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] [FiniteDimensional E K'] (h : IsRadicalTower E K')
    (h_three_le : 3 ≤ Module.finrank E K') : False := by
  have h_finrank_le : Module.finrank E K' ≤ 2 :=
    IsRadicalTower.finrank_le_two_of_field (E := E) (K' := K') h
  have h_contra : (3 : ℕ) ≤ 2 := le_trans h_three_le h_finrank_le
  exact (Nat.not_succ_le_self 2) h_contra

/-- Finite Galois size bound for radical-tower subextensions (auxiliary form). -/
lemma IsRadicalTower.card_galois_le_two_of_ne_bot_finite_aux {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] (h : IsRadicalTower E K') (L : IntermediateField E K')
    [FiniteDimensional E L] [IsGalois E L] [Finite (Gal(L/E))] (_hL : L ≠ ⊥) :
    Nat.card (Gal(L/E)) ≤ 2 := by
  classical
  -- Reduce to a finrank bound via the Galois group cardinality formula.
  have h_card_eq : Nat.card (Gal(L/E)) = Module.finrank E L := by
    simpa using (IsGalois.card_aut_eq_finrank (F := E) (E := L))
  -- TODO: This finrank bound is not derivable from the current definition of `IsRadicalTower`.
  -- It likely requires extra hypotheses (e.g. real-embeddability or quadratic-only steps).
  have h_finrank_le : Module.finrank E L ≤ 2 := by
    have hfinite_K' : Module.Finite E K' :=
      IsRadicalTower.moduleFinite (E := E) (F := K') h
    haveI : FiniteDimensional E K' := hfinite_K'
    have h_finrank_le_top :
        Module.finrank E L ≤ Module.finrank E (⊤ : IntermediateField E K') :=
      IntermediateField.finrank_le_of_le_right (K := E) (L := K') (F := L) (E := ⊤)
        (h := le_top)
    have h_finrank_le_K' : Module.finrank E L ≤ Module.finrank E K' := by
      simpa using h_finrank_le_top
    have h_finrank_le_two : Module.finrank E K' ≤ 2 :=
      IsRadicalTower.finrank_le_two_of_field (E := E) (K' := K') h
    exact le_trans h_finrank_le_K' h_finrank_le_two
  rw [h_card_eq]
  exact h_finrank_le

/-- Finite Galois case of the finrank bound for radical-tower subextensions. -/
lemma IsRadicalTower.finrank_le_two_of_ne_bot_finite {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] (h : IsRadicalTower E K') (L : IntermediateField E K')
    [FiniteDimensional E L] [IsGalois E L] [Finite (Gal(L/E))] (hL : L ≠ ⊥) :
    Module.finrank E L ≤ 2 := by
  classical
  have h_card_le : Nat.card (Gal(L/E)) ≤ 2 :=
    IsRadicalTower.card_galois_le_two_of_ne_bot_finite_aux (E := E) (K' := K') h L hL
  have h_card_eq : Nat.card (Gal(L/E)) = Module.finrank E L := by
    simpa using (IsGalois.card_aut_eq_finrank (F := E) (E := L))
  rw [← h_card_eq]
  exact h_card_le

/-- Finite Galois case of the size bound for radical-tower subextensions. -/
lemma IsRadicalTower.card_galois_le_two_of_ne_bot_finite {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] (h : IsRadicalTower E K') (L : IntermediateField E K')
    [FiniteDimensional E L] [IsGalois E L] [Finite (Gal(L/E))] (hL : L ≠ ⊥) :
    Nat.card (Gal(L/E)) ≤ 2 := by
  classical
  have h_card_eq : Nat.card (Gal(L/E)) = Module.finrank E L := by
    simpa using (IsGalois.card_aut_eq_finrank (F := E) (E := L))
  have h_finrank_le : Module.finrank E L ≤ 2 :=
    IsRadicalTower.finrank_le_two_of_ne_bot_finite (E := E) (K' := K') h L hL
  rw [h_card_eq]
  exact h_finrank_le

/-- Missing bound: the Galois group of a nontrivial subextension in a radical tower has small order. -/
lemma IsRadicalTower.card_galois_le_two_of_ne_bot {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] (h : IsRadicalTower E K') (L : IntermediateField E K')
    [FiniteDimensional E L] [IsGalois E L] (hL : L ≠ ⊥) :
    Nat.card (Gal(L/E)) ≤ 2 := by
  classical
  cases (finite_or_infinite (Gal(L/E))) with
  | inl hfinite =>
      haveI : Finite (Gal(L/E)) := hfinite
      exact
        IsRadicalTower.card_galois_le_two_of_ne_bot_finite (E := E) (K' := K') h L hL
  | inr hinfinite =>
      have hcard : Nat.card (Gal(L/E)) = 0 := by
        simpa using (Nat.card_eq_zero_of_infinite (α := Gal(L/E)))
      rw [hcard]
      exact Nat.zero_le 2

/-- A nontrivial finite Galois subextension of a radical tower cannot have degree at least `3`. -/
lemma IsRadicalTower.galois_subextension_three_le_false_of_ne_bot_aux {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] (h : IsRadicalTower E K') (L : IntermediateField E K')
    [FiniteDimensional E L] [IsGalois E L] (hL : L ≠ ⊥)
    (h_three_le : 3 ≤ Module.finrank E L) :
    False := by
  classical
  -- Translate the degree bound into a statement about the size of the Galois group.
  have h_card_eq : Nat.card (Gal(L/E)) = Module.finrank E L := by
    simpa using (IsGalois.card_aut_eq_finrank (F := E) (E := L))
  have h_three_le' : 3 ≤ Nat.card (Gal(L/E)) := by
    rw [h_card_eq]
    exact h_three_le
  -- TODO: need a genuine restriction on the Galois group of a radical-tower subextension.
  have h_card_le : Nat.card (Gal(L/E)) ≤ 2 :=
    IsRadicalTower.card_galois_le_two_of_ne_bot (E := E) (K' := K') h L hL
  have h_contra : (3 : ℕ) ≤ 2 := le_trans h_three_le' h_card_le
  exact (Nat.not_succ_le_self 2) h_contra

/-- A nontrivial finite Galois subextension of a radical tower should have small degree. -/
lemma IsRadicalTower.galois_subextension_finrank_le_two_of_ne_bot {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] (h : IsRadicalTower E K') (L : IntermediateField E K')
    [FiniteDimensional E L] [IsGalois E L] (hL : L ≠ ⊥) :
    Module.finrank E L ≤ 2 := by
  classical
  by_contra h_le
  have h_lt : 2 < Module.finrank E L := lt_of_not_ge h_le
  have h_three_le : 3 ≤ Module.finrank E L := (Nat.succ_le_iff).2 h_lt
  exact
    IsRadicalTower.galois_subextension_three_le_false_of_ne_bot_aux
      (E := E) (K' := K') h L hL h_three_le

/-- The nontrivial case of the degree-`≥ 3` obstruction for Galois subextensions. -/
lemma IsRadicalTower.galois_subextension_three_le_false_of_ne_bot {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] (h : IsRadicalTower E K') (L : IntermediateField E K')
    [FiniteDimensional E L] [IsGalois E L] (hL : L ≠ ⊥)
    (h_three_le : 3 ≤ Module.finrank E L) :
    False := by
  have h_le_two :
      Module.finrank E L ≤ 2 :=
    IsRadicalTower.galois_subextension_finrank_le_two_of_ne_bot
      (E := E) (K' := K') h L hL
  have h_contra : (3 : ℕ) ≤ 2 := le_trans h_three_le h_le_two
  exact (Nat.not_succ_le_self 2) h_contra

/-- A finite Galois subextension of a radical tower cannot have degree at least `3`. -/
lemma IsRadicalTower.galois_subextension_three_le_false {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] (h : IsRadicalTower E K') (L : IntermediateField E K')
    [FiniteDimensional E L] [IsGalois E L]
    (h_three_le : 3 ≤ Module.finrank E L) :
    False := by
  by_cases hL : L = ⊥
  · subst hL
    simp at h_three_le
  · exact
      IsRadicalTower.galois_subextension_three_le_false_of_ne_bot
        (E := E) (K' := K') h L hL h_three_le

/-- An odd-degree finite Galois subextension of a radical tower is trivial. -/
lemma IsRadicalTower.galois_subextension_odd_eq_one {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] (h : IsRadicalTower E K') (L : IntermediateField E K')
    [FiniteDimensional E L] [IsGalois E L]
    (h_odd : Odd (Module.finrank E L)) :
    Module.finrank E L = 1 := by
  classical
  by_cases hL : (L = ⊥)
  · subst hL
    simp
  · -- TODO: need a degree restriction on odd-degree Galois subextensions inside a radical tower.
    -- This would imply `Module.finrank E L = 1` when `L ≠ ⊥`.
    have h_ne_one : Module.finrank E L ≠ 1 :=
      IntermediateField.finrank_ne_one_of_ne_bot (E := E) (K := K') (L := L) hL
    have h_three_le : 3 ≤ Module.finrank E L :=
      odd_ne_one_three_le h_odd h_ne_one
    have h_false :
        False :=
      IsRadicalTower.galois_subextension_three_le_false (E := E) (K' := K') h L h_three_le
    exact (False.elim h_false)

/-- Any finite Galois subextension of a radical tower has degree `1` or even. -/
lemma IsRadicalTower.galois_subextension_even_or_one {E K' : Type u} [Field E] [Field K']
    [Algebra E K'] (h : IsRadicalTower E K') (L : IntermediateField E K')
    [FiniteDimensional E L] [IsGalois E L] :
    Module.finrank E L = 1 ∨ Even (Module.finrank E L) := by
  classical
  have h_even_or_odd : Even (Module.finrank E L) ∨ Odd (Module.finrank E L) :=
    Nat.even_or_odd (Module.finrank E L)
  cases h_even_or_odd with
  | inl h_even =>
      exact Or.inr h_even
  | inr h_odd =>
      left
      exact
        IsRadicalTower.galois_subextension_odd_eq_one
          (E := E) (K' := K') h L h_odd

set_option maxHeartbeats 400000 in
set_option synthInstance.maxHeartbeats 100000 in
-- Needed for typeclass search on module structures over subfields/intermediate fields.
/-- Reduction: an algebra embedding into a real radical tower yields a rank bound that
needs a radical-tower degree restriction to contradict odd-degree Galois data. -/
lemma radicalTower_no_galois_odd_embedding (E : Subfield ℝ) (K : Type)
    [Field K] [Algebra E K] [IsGalois E K] (n : ℕ) (h_odd : Odd n) (hn : n > 1)
    (h_deg_eq : Module.rank E K = n) (K' : IntermediateField E ℝ)
    (h_radical : IsRadicalTower E K') (f : K →ₐ[E] K') :
  False := by
  classical
  haveI : FiniteDimensional E K :=
    FiniteDimensional.of_rank_eq_nat (K := E) (V := K) h_deg_eq
  let L : IntermediateField E K' := f.fieldRange
  have hL_finrank : Module.finrank E L = n := by
    have hL_eq : Module.finrank E L = Module.finrank E K := by
      simpa [L] using
        (AlgHom.finrank_fieldRange_eq (E := E) (K := K) (L := K') f)
    have hK_finrank : Module.finrank E K = n :=
      Module.finrank_eq_of_rank_eq h_deg_eq
    simpa [hK_finrank] using hL_eq
  have hL_finrank_succ : Module.finrank E L = n - 1 + 1 := by
    have h_le : 1 ≤ n := Nat.le_of_lt hn
    have h_eq : n - 1 + 1 = n := Nat.sub_add_cancel h_le
    exact hL_finrank.trans h_eq.symm
  have hL_finrank_succ' : Module.finrank E L = (n - 1).succ := by
    simpa [Nat.succ_eq_add_one] using hL_finrank_succ
  haveI : FiniteDimensional E L :=
    FiniteDimensional.of_finrank_eq_succ (n := n - 1) hL_finrank_succ'
  have hL_galois : IsGalois E L := by
    simpa [L] using
      (AlgHom.fieldRange_isGalois (E := E) (K := K) (L := K') f)
  haveI : IsGalois E L := hL_galois
  have hL_even_or_one :
      Module.finrank E L = 1 ∨ Even (Module.finrank E L) :=
    IsRadicalTower.galois_subextension_even_or_one (E := E) (K' := K') h_radical L
  cases hL_even_or_one with
  | inl hL_one =>
      have h_n_eq_one : n = 1 := by
        simpa [hL_finrank] using hL_one
      have hcontra : (1 : ℕ) < 1 := by
        have hn' : (1 : ℕ) < n := hn
        simp [h_n_eq_one] at hn'
      exact (lt_irrefl _ hcontra)
  | inr hL_even =>
      have h_even_n : Even n := by
        simpa [hL_finrank] using hL_even
      have h_not_even : ¬ Even n := (Nat.not_even_iff_odd).2 h_odd
      exact h_not_even h_even_n

/--
Let \( E \) be a subfield of \( \mathbb{R} \) and let \( K/E \) be a finite Galois extension of odd degree \( > 1 \).
Prove that \( K \) cannot be \( E \)-embedded into a radical tower that is a subfield of \( \mathbb{R} \).
-/
theorem isEmpty_embedding_intermediateField_of_odd_degree_galois (E : Subfield ℝ) (K : Type)
    [Field K] [Algebra E K] [IsGalois E K] (n : ℕ) (h_odd : Odd n) (hn : n > 1) (h_deg_eq : Module.rank E K = n)
    (K' : IntermediateField E ℝ) (h_radical : IsRadicalTower E K') :
    IsEmpty (K →ₐ[E] K') := by
  classical
  refine ⟨?_⟩
  intro f
  exact
    radicalTower_no_galois_odd_embedding (E := E) (K := K) (n := n)
      h_odd hn h_deg_eq (K' := K') h_radical f
