import Mathlib

/- 
Let $K/\mathbb{Q}$ be a finite extension. Let $g$ be an element of the absolute Galois group $G(K)$ of $K$.
Show that the subgroup generated by $g$ is closed in $G(K)$ if and only if $g$ is torsion.
-/
/-- A countable compact Hausdorff topological group is finite. -/
lemma finite_of_countable_compact_topologicalGroup (G : Type*)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [CompactSpace G]
    [Countable G] [T2Space G] : Finite G := by
  classical
  letI : MeasurableSpace G := borel G
  letI : BorelSpace G := ⟨rfl⟩
  let K₀ : TopologicalSpace.PositiveCompacts G := ⊤
  let μ : MeasureTheory.Measure G := MeasureTheory.Measure.haarMeasure K₀
  have hμ_univ : μ (Set.univ : Set G) = 1 := by
    simpa [K₀] using (MeasureTheory.Measure.haarMeasure_self (K₀ := K₀))
  have hμ_singleton (g : G) : μ ({g} : Set G) = μ ({(1 : G)} : Set G) := by
    simp
  by_contra hfin
  have hInf : Infinite G := not_finite_iff_infinite.mp hfin
  haveI : Infinite G := hInf
  have hμ1_zero : μ ({(1 : G)} : Set G) = 0 := by
    by_contra hμ1_ne
    have hμ_univ_top : μ (Set.univ : Set G) = ⊤ := by
      refine Set.Infinite.meas_eq_top (μ := μ) (s := (Set.univ : Set G)) ?_ ?_
      · simpa using (Set.infinite_univ : (Set.univ : Set G).Infinite)
      · refine ⟨μ ({(1 : G)} : Set G), hμ1_ne, ?_⟩
        intro x hx
        have hx' : μ ({x} : Set G) = μ ({(1 : G)} : Set G) := by
          exact hμ_singleton x
        exact le_of_eq hx'.symm
    have hμ_univ_top' := hμ_univ_top
    rw [hμ_univ] at hμ_univ_top'
    exact (ENNReal.one_ne_top hμ_univ_top')
  have hcount : (Set.univ : Set G).Countable := Set.countable_univ
  have huniv_nonempty : (Set.univ : Set G).Nonempty := by
    simp
  obtain ⟨f, hf⟩ := hcount.exists_surjective huniv_nonempty
  let f' : ℕ → G := fun n => (f n).1
  have hf' : Function.Surjective f' := by
    intro x
    obtain ⟨n, hn⟩ := hf ⟨x, trivial⟩
    refine ⟨n, ?_⟩
    simpa using congrArg Subtype.val hn
  have huniv : (⋃ n, ({f' n} : Set G)) = (Set.univ : Set G) := by
    simp [Set.iUnion_singleton_eq_range, Set.range_eq_univ.mpr hf']
  have hμ_univ_zero : μ (Set.univ : Set G) = 0 := by
    have hzero : ∀ n, μ ({f' n} : Set G) = 0 := by
      intro n
      have : μ ({f' n} : Set G) = μ ({(1 : G)} : Set G) := by
        exact hμ_singleton (f' n)
      simp [this, hμ1_zero]
    have : μ (⋃ n, ({f' n} : Set G)) = 0 := MeasureTheory.measure_iUnion_null hzero
    simpa [huniv] using this
  have hμ_univ_zero' := hμ_univ_zero
  rw [hμ_univ] at hμ_univ_zero'
  exact (one_ne_zero hμ_univ_zero')

/-- In a compact Hausdorff topological group, a closed cyclic subgroup forces torsion. -/
lemma isOfFinOrder_of_isClosed_zpowers_of_compact (G : Type*)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [CompactSpace G] [T2Space G]
    (g : G) (hclosed : IsClosed ((Subgroup.zpowers g : Set G))) : IsOfFinOrder g := by
  have hcomp : IsCompact ((Subgroup.zpowers g : Set G)) := hclosed.isCompact
  haveI : CompactSpace (Subgroup.zpowers g) := isCompact_iff_compactSpace.mp hcomp
  have hfin : Finite (Subgroup.zpowers g) :=
    finite_of_countable_compact_topologicalGroup (G := Subgroup.zpowers g)
  have hfin_set : ((Subgroup.zpowers g : Set G)).Finite := by
    simpa using (Set.finite_coe_iff.mp (show Finite (Subgroup.zpowers g) from hfin))
  exact (finite_zpowers).1 hfin_set

theorem isClosed_zpowers_iff_isOfFinOrder (K : Type)
    [Field K] [Algebra ℚ K] [Module.Finite ℚ K] (g : Field.absoluteGaloisGroup K) :
    IsClosed ((Subgroup.zpowers g) : Set (Field.absoluteGaloisGroup K)) ↔ IsOfFinOrder g := by
  classical
  haveI : CharZero K := charZero_of_injective_algebraMap (algebraMap ℚ K).injective
  haveI : IsGalois K (AlgebraicClosure K) := by infer_instance
  haveI : T2Space (Field.absoluteGaloisGroup K) := by
    simpa [Field.absoluteGaloisGroup] using
      (krullTopology_t2 (K := K) (L := AlgebraicClosure K))
  haveI : CompactSpace (Field.absoluteGaloisGroup K) := by
    simpa [Field.absoluteGaloisGroup] using
      (inferInstance : CompactSpace (Gal(AlgebraicClosure K/K)))
  constructor
  · intro hclosed
    exact isOfFinOrder_of_isClosed_zpowers_of_compact (G := Field.absoluteGaloisGroup K) g hclosed
  · intro hfin
    exact hfin.finite_zpowers.isClosed
