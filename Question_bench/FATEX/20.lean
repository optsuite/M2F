import Mathlib

/-- A prime-degree finite field extension is generated by one element. -/
lemma exists_generator_of_finrank_eq_prime
    (F E : Type*) [Field F] [Field E] [Algebra F E] [FiniteDimensional F E]
    (p : ℕ) [Fact (Nat.Prime p)] (hfin : Module.finrank F E = p) :
    ∃ x : E, IntermediateField.adjoin F {x} = ⊤ := by
  classical
  have hprime : Nat.Prime (Module.finrank F E) := by
    simpa [hfin] using (Fact.out : Nat.Prime p)
  have hsimple : IsSimpleOrder (IntermediateField F E) :=
    IntermediateField.isSimpleOrder_of_finrank_prime (F := F) (E := E) hprime
  have hbotne : (⊥ : IntermediateField F E) ≠ ⊤ := by
    intro hbot
    have h1 : Module.finrank F E = 1 :=
      (IntermediateField.bot_eq_top_iff_finrank_eq_one (F := F) (E := E)).1 hbot
    exact (Nat.ne_of_gt (Nat.Prime.one_lt hprime)) h1
  obtain ⟨x, hx⟩ : ∃ x : E, x ∉ (⊥ : IntermediateField F E) :=
    SetLike.exists_not_mem_of_ne_top (s := (⊥ : IntermediateField F E)) hbotne
  have hx' : IntermediateField.adjoin F ({x} : Set E) ≠ ⊥ := by
    intro hbot
    have hxmem : x ∈ (IntermediateField.adjoin F ({x} : Set E)) :=
      IntermediateField.subset_adjoin (F := F) (S := {x}) (by simp)
    have : x ∈ (⊥ : IntermediateField F E) := by simpa [hbot] using hxmem
    exact hx this
  have htop : IntermediateField.adjoin F ({x} : Set E) = ⊤ := by
    cases hsimple.eq_bot_or_eq_top (IntermediateField.adjoin F ({x} : Set E)) with
    | inl h => exact (hx' h).elim
    | inr h => exact h
  exact ⟨x, by simpa using htop⟩

/-- If `x` generates `L` over an intermediate field `F`, then `F ⊔ K⟮x⟯ = ⊤`. -/
lemma sup_adjoin_eq_top_of_adjoin_eq_top
    {K L : Type*} [Field K] [Field L] [Algebra K L]
    (F : IntermediateField K L) {x : L}
    (hx : IntermediateField.adjoin F ({x} : Set L) = ⊤) :
    F ⊔ IntermediateField.adjoin K ({x} : Set L) = ⊤ := by
  have hx' :
      IntermediateField.restrictScalars K (IntermediateField.adjoin F ({x} : Set L)) =
        (⊤ : IntermediateField K L) := by
    simpa using (congrArg (IntermediateField.restrictScalars K) hx)
  simpa [IntermediateField.restrictScalars_adjoin_eq_sup] using hx'

/-- The `p`-th power of any element lies in the adjoin of the Frobenius range. -/
lemma pow_mem_adjoin_frobenius_range
    (p : ℕ) [Fact (Nat.Prime p)] {K L : Type*} [Field K] [Field L] [CharP L p] [Algebra K L]
    (z : L) :
    z ^ p ∈ (IntermediateField.adjoin K ((frobenius L p).range : Set L) : Set L) := by
  have hz : z ^ p ∈ (frobenius L p).range := by
    refine ⟨z, ?_⟩
    simp [frobenius_def]
  exact
    (IntermediateField.subset_adjoin (F := K)
      (S := ((frobenius L p).range : Set L)) hz)

/-- The Frobenius range is contained in `F = K(L^p)`. -/
lemma frobenius_range_subset_adjoin_frobenius
    (p : ℕ) [Fact (Nat.Prime p)] {K L : Type*} [Field K] [Field L] [CharP L p] [Algebra K L]
    (F : IntermediateField K L)
    (hF : F = IntermediateField.adjoin K ((frobenius L p).range : Set L)) :
    ((frobenius L p).range : Set L) ⊆ (F : Set L) := by
  intro y hy
  rcases hy with ⟨z, rfl⟩
  simpa [hF] using (pow_mem_adjoin_frobenius_range (K := K) (L := L) p z)

/-- Reduce `F ≤ K⟮x⟯` to a Frobenius-range subset statement. -/
lemma adjoin_frobenius_le_adjoin_iff
    (p : ℕ) [Fact (Nat.Prime p)] {K L : Type*} [Field K] [Field L] [CharP L p] [Algebra K L]
    (F : IntermediateField K L) {x : L}
    (hF : F = IntermediateField.adjoin K ((frobenius L p).range : Set L)) :
    F ≤ IntermediateField.adjoin K ({x} : Set L) ↔
      ((frobenius L p).range : Set L) ⊆ (IntermediateField.adjoin K ({x} : Set L) : Set L) := by
  simp [hF]

/-- If `F ≤ K⟮x⟯`, then the Frobenius range lies in `K⟮x⟯`. -/
lemma frobenius_range_subset_adjoin_of_le
    (p : ℕ) [Fact (Nat.Prime p)] {K L : Type*} [Field K] [Field L] [CharP L p] [Algebra K L]
    (F : IntermediateField K L) {x : L}
    (hFK : F ≤ IntermediateField.adjoin K ({x} : Set L))
    (hF : F = IntermediateField.adjoin K ((frobenius L p).range : Set L)) :
    ((frobenius L p).range : Set L) ⊆ (IntermediateField.adjoin K ({x} : Set L) : Set L) := by
  intro y hy
  have hyF : y ∈ (F : Set L) :=
    frobenius_range_subset_adjoin_frobenius (K := K) (L := L) (F := F) p hF hy
  exact hFK hyF

/-- If `F ≰ E`, then `F ≠ ⊥`. -/
lemma ne_bot_of_not_le
    {K L : Type*} [Field K] [Field L] [Algebra K L]
    (F E : IntermediateField K L)
    (hFE : ¬ F ≤ E) :
    (F : IntermediateField K L) ≠ ⊥ := by
  intro hFbot
  apply hFE
  simp [hFbot]

/-- Missing lattice contradiction used in the Jacobson upgrade step. -/
lemma sup_eq_top_contra_of_ne_bot
    {K L : Type*} [Field K] [Field L] [Algebra K L]
    (F E : IntermediateField K L)
    (hsup : F ⊔ E = ⊤)
    (hFbot : (F : IntermediateField K L) ≠ ⊥)
    (htop : E ≠ ⊤)
    (hFE : ¬ F ≤ E) :
    False := by
  -- The required lattice-theoretic contradiction is still missing.
  sorry

/-- Lattice upgrade step: a proper simple subfield should absorb any join to top. -/
lemma sup_eq_top_le_of_not_top
    {K L : Type*} [Field K] [Field L] [Algebra K L]
    (F E : IntermediateField K L)
    (hsup : F ⊔ E = ⊤)
    (htop : E ≠ ⊤) :
    F ≤ E := by
  classical
  by_cases hFE : F ≤ E
  · exact hFE
  ·
    -- The nontrivial Jacobson-type upgrade is missing here.
    have hFbot : (F : IntermediateField K L) ≠ ⊥ :=
      ne_bot_of_not_le (K := K) (L := L) (F := F) (E := E) hFE
    have hcontra :
        False :=
      sup_eq_top_contra_of_ne_bot (K := K) (L := L) (F := F) (E := E) hsup hFbot htop hFE
    exact hcontra.elim

/-- Nontrivial Jacobson step: upgrade `F ⊔ K⟮x⟯ = ⊤` to `F ≤ K⟮x⟯` when `K⟮x⟯ ≠ ⊤`. -/
lemma adjoin_frobenius_le_adjoin_of_sup_eq_top
    {K L : Type*} [Field K] [Field L] [Algebra K L]
    (F : IntermediateField K L) {x : L}
    (hsup : F ⊔ IntermediateField.adjoin K ({x} : Set L) = ⊤)
    (htop :
      (IntermediateField.adjoin K ({x} : Set L) : IntermediateField K L) ≠ ⊤) :
    F ≤ IntermediateField.adjoin K ({x} : Set L) := by
  simpa using
    (sup_eq_top_le_of_not_top (K := K) (L := L) (F := F)
      (E := IntermediateField.adjoin K ({x} : Set L)) hsup htop)

/-- Jacobson-style upgrade: the Frobenius range lies in `K⟮x⟯` under `F⟮x⟯ = ⊤`. -/
lemma frobenius_range_subset_adjoin_of_adjoin_eq_top
    (p : ℕ) [Fact (Nat.Prime p)] {K L : Type*} [Field K] [Field L] [CharP L p] [Algebra K L]
    (F : IntermediateField K L) {x : L}
    (hx : IntermediateField.adjoin F ({x} : Set L) = ⊤)
    (hF : F = IntermediateField.adjoin K ((frobenius L p).range : Set L)) :
    ((frobenius L p).range : Set L) ⊆ (IntermediateField.adjoin K ({x} : Set L) : Set L) := by
  classical
  -- First collapse `F⟮x⟯ = ⊤` to a join statement over `K`.
  have hsup : F ⊔ IntermediateField.adjoin K ({x} : Set L) = ⊤ :=
    sup_adjoin_eq_top_of_adjoin_eq_top (K := K) (L := L) F (x := x) hx
  -- TODO: upgrade `hsup` to the inclusion `F ≤ K⟮x⟯`.
  -- This is the missing Jacobson-type step.
  have hFK : F ≤ IntermediateField.adjoin K ({x} : Set L) := by
    -- The remaining goal is `F ≤ K⟮x⟯`.
    -- This is the missing Jacobson-type step.
    by_cases htop :
        (IntermediateField.adjoin K ({x} : Set L) : IntermediateField K L) = ⊤
    · simp [htop]
    ·
      exact
        adjoin_frobenius_le_adjoin_of_sup_eq_top (K := K) (L := L) (F := F) (x := x) hsup htop
  -- Once `F ≤ K⟮x⟯`, the Frobenius range inclusion follows.
  exact
    frobenius_range_subset_adjoin_of_le (K := K) (L := L) (F := F) (x := x) p hFK hF

/-- If `x` generates `L` over `F = K(L^p)`, then `F ≤ K⟮x⟯`. -/
lemma adjoin_frobenius_le_adjoin
    (p : ℕ) [Fact (Nat.Prime p)] {K L : Type*} [Field K] [Field L] [CharP L p] [Algebra K L]
    (F : IntermediateField K L) {x : L}
    (hx : IntermediateField.adjoin F ({x} : Set L) = ⊤)
    (hF : F = IntermediateField.adjoin K ((frobenius L p).range : Set L)) :
    F ≤ IntermediateField.adjoin K ({x} : Set L) := by
  classical
  -- Reduce to showing the Frobenius range lies in `K⟮x⟯`.
  have hsubset :
      ((frobenius L p).range : Set L) ⊆ (IntermediateField.adjoin K ({x} : Set L) : Set L) :=
    frobenius_range_subset_adjoin_of_adjoin_eq_top (K := K) (L := L) (F := F) (x := x) p hx hF
  exact (adjoin_frobenius_le_adjoin_iff (K := K) (L := L) (F := F) (x := x) p hF).2 hsubset

/-- Jacobson-style upgrade: the Frobenius range lies in `K⟮x⟯`. -/
lemma frobenius_range_subset_adjoin
    (p : ℕ) [Fact (Nat.Prime p)] {K L : Type*} [Field K] [Field L] [CharP L p] [Algebra K L]
    (F : IntermediateField K L) {x : L}
    (hx : IntermediateField.adjoin F ({x} : Set L) = ⊤)
    (hF : F = IntermediateField.adjoin K ((frobenius L p).range : Set L)) :
    ((frobenius L p).range : Set L) ⊆ (IntermediateField.adjoin K ({x} : Set L) : Set L) := by
  exact
    frobenius_range_subset_adjoin_of_adjoin_eq_top (K := K) (L := L) (F := F) (x := x) p hx hF

/--
Let $p$ be a prime number. Let $L/K$ be a finite extension of fields of characteristic $p$,
and let $\sigma:x\mapsto x^p$ denote the $p$-Frobenius endomorphism on $L$, which of course stabilizes $K$.
Prove that if $[L:K\sigma(L)] \leq p$, then $L/K$ can be generated by one element.
-/
theorem generated_single_elem_of_degree_le_p (p : ℕ) [Fact (Nat.Prime p)]
    (K L : Type) [Field K] [Field L] [CharP L p] [Algebra K L] [FiniteDimensional K L]
    (h : Module.rank (IntermediateField.adjoin K ((frobenius L p).range : Set L)) L ≤ p) :
    ∃ (x : L), IntermediateField.adjoin K {x} = ⊤ := by
  classical
  let F : IntermediateField K L := IntermediateField.adjoin K ((frobenius L p).range : Set L)
  -- The subextension `K(L^p) ⊂ L` is purely inseparable.
  have hpi : IsPurelyInseparable F L := by
    -- Use the Frobenius range: `x ↦ x^p` lands in `K(L^p)`.
    haveI : CharP F p := inferInstance
    haveI : ExpChar F p := inferInstance
    refine (isPurelyInseparable_iff_pow_mem F p).2 ?_
    intro x
    refine ⟨1, ?_⟩
    have hx' : x ^ p ∈ (frobenius L p).range := by
      refine ⟨x, ?_⟩
      simp [frobenius_def]
    have hx : x ^ p ∈ F := by
      simpa [F] using
        (IntermediateField.subset_adjoin (F := K)
          (S := ((frobenius L p).range : Set L)) hx')
    refine ⟨⟨x ^ p, hx⟩, ?_⟩
    simp [pow_one]
  -- The degree `[L : K(L^p)]` is `1` or `p`.
  have hdeg : Module.finrank F L = 1 ∨ Module.finrank F L = p := by
    haveI : IsPurelyInseparable F L := hpi
    have hfinrank : Module.finrank F L ≤ p := by
      simpa [F] using (Module.finrank_le_of_rank_le (R := F) (M := L) h)
    obtain ⟨n, hn⟩ := IsPurelyInseparable.finrank_eq_pow (F := F) (E := L) p
    have hp1 : 1 < p := (Fact.out : Nat.Prime p).one_lt
    have hn_le : n ≤ 1 := by
      have hpow : p ^ n ≤ p ^ 1 := by
        have : p ^ n ≤ p := by simpa [hn] using hfinrank
        simpa [pow_one] using this
      exact (Nat.pow_le_pow_iff_right hp1).1 hpow
    cases n with
    | zero =>
        left
        simp [hn]
    | succ n =>
        cases n with
        | zero =>
            right
            simp [hn]
        | succ n =>
            exfalso
            have h' : Nat.succ n < 1 := (Nat.succ_le_iff.mp hn_le)
            have h'' : n < 0 := by
              exact (Nat.succ_lt_succ_iff.mp h')
            exact (Nat.not_lt_zero _ h'')
  have hgenF : ∃ x : L, IntermediateField.adjoin F {x} = ⊤ := by
    cases hdeg with
    | inl h1 =>
        have hbot :
            (⊥ : IntermediateField F L) = ⊤ :=
          (IntermediateField.bot_eq_top_iff_finrank_eq_one (F := F) (E := L)).2 h1
        haveI : Subsingleton (IntermediateField F L) := subsingleton_of_bot_eq_top hbot
        exact ⟨0, Subsingleton.elim _ _⟩
    | inr hp =>
        exact exists_generator_of_finrank_eq_prime F L p hp
  obtain ⟨x, hx⟩ := hgenF
  have hx_sup : F ⊔ IntermediateField.adjoin K {x} = ⊤ :=
    sup_adjoin_eq_top_of_adjoin_eq_top F (x := x) hx
  -- TODO: upgrade a primitive element over `F = K(L^p)` to a primitive element over `K`
  -- by showing `F ≤ K⟮x⟯`.
  have hxK : IntermediateField.adjoin K {x} = ⊤ := by
    have hFK : F ≤ IntermediateField.adjoin K {x} := by
      -- Reduce to showing that the Frobenius range lies in `K⟮x⟯`.
      change
        IntermediateField.adjoin K ((frobenius L p).range : Set L) ≤
          IntermediateField.adjoin K {x}
      refine (IntermediateField.adjoin_le_iff).2 ?_
      intro y hy
      have hF' : F = IntermediateField.adjoin K ((frobenius L p).range : Set L) := by
        rfl
      exact frobenius_range_subset_adjoin p (F := F) (x := x) hx hF' hy
    -- If `F ≤ K⟮x⟯`, the join in `hx_sup` collapses to `K⟮x⟯`.
    calc
      IntermediateField.adjoin K {x}
          = F ⊔ IntermediateField.adjoin K {x} := (sup_eq_right.2 hFK).symm
      _ = ⊤ := hx_sup
  exact ⟨x, hxK⟩
