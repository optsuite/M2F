import Mathlib

open Module
open Polynomial

/-- A primitive `p^2`-th root of unity gives a nonempty set of primitive roots. -/
lemma FATEX27.primitiveRoots_p2_nonempty (p : ℕ) (hp : p.Prime) {K : Type} [Field K] {ζ : K}
    (h : IsPrimitiveRoot ζ (p^2)) : (primitiveRoots (p^2) K).Nonempty := by
  classical
  refine ⟨ζ, ?_⟩
  have hpos : 0 < p ^ 2 := by
    exact pow_pos hp.pos 2
  exact (mem_primitiveRoots (R:=K) (k:=p^2) hpos).2 h

