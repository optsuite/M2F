/--
Let $p$ be a prime number. Let $K/\mathbb{Q}$ be a finite extension, such that the $p^{2}$th root of unity is contained in $K$.
Let $L/K$ be a Galois extension of degree $p$, show that there exists a Galois extension $L'/L$ of degree $p$,
such that the extension $L'/K$ is Galois.
-/
theorem isGalois_and_rank_eq_of_isPrimitiveRoot_sq (p : ℕ) (hp : p.Prime) {K : Type} [Field K]
    [NumberField K] {ζ : K} (h : IsPrimitiveRoot ζ (p^2))
    {L : IntermediateField K (AlgebraicClosure K)} [IsGalois K L]
    (hdeg : Module.rank K L = p) :
    ∃ (L' : Type) (_ : Field L') (_ : Algebra K L')
    (_ : Algebra L L') (_ : IsScalarTower K L L'),
    IsGalois K L' ∧ IsGalois L L' ∧ Module.rank L L' = p := by
  classical
  -- Convert the rank hypothesis into finrank and obtain finite dimensionality.
  have hfinrank : finrank K L = p := by
    simpa using (Module.finrank_eq_of_rank_eq (R:=K) (M:=L) hdeg)
  haveI : FiniteDimensional K L := by
    refine FiniteDimensional.of_finrank_pos ?_
    simpa [hfinrank] using hp.pos

  -- Produce a primitive p-th root of unity in K from the given p²-th root.
  have hprim : (primitiveRoots (finrank K L) K).Nonempty := by
    classical
    have hζp : IsPrimitiveRoot (ζ ^ p) p := by
      have hpos : 0 < p ^ 2 := by
        exact pow_pos hp.pos 2
      have hprod : p ^ 2 = p * p := by
        simp [pow_two]
      exact IsPrimitiveRoot.pow (n:=p^2) (a:=p) (b:=p) hpos h hprod
    refine ⟨ζ ^ p, ?_⟩
    have hpos' : 0 < finrank K L := by
      simpa [hfinrank] using hp.pos
    exact (mem_primitiveRoots (R:=K) (k:=finrank K L) hpos').2 (by simpa [hfinrank] using hζp)

  -- The Galois group has prime order, hence it is cyclic.
  have hcyc : IsCyclic Gal(L/K) := by
    classical
    let _ : Fact p.Prime := ⟨hp⟩
    have hcard : Nat.card Gal(L/K) = p := by
      simpa [hfinrank] using (IsGalois.card_aut_eq_finrank (F:=K) (E:=L))
    exact isCyclic_of_prime_card (α:=Gal(L/K)) (p:=p) hcard

  -- Extract the Kummer polynomial X^p - a whose splitting field is L.
  have hgalcyc : IsGalois K L ∧ IsCyclic Gal(L/K) :=
    ⟨(inferInstance : IsGalois K L), hcyc⟩
  obtain ⟨a, hIrred, hSplit⟩ :=
    ((isCyclic_tfae K L hprim).out 0 1).mp hgalcyc
  have hIrred' : Irreducible (X ^ p - C a) := by
    simpa [hfinrank] using hIrred
  have hSplit' : IsSplittingField K L (X ^ p - C a) := by
    simpa [hfinrank] using hSplit

  -- Remaining step: build the p²-Kummer splitting field inside the algebraic closure,
  -- show it contains L, and compute the relative rank.
  -- This is the remaining Kummer-theoretic construction.
  classical
  let g : K[X] := X ^ (p^2) - C a
  let L' : IntermediateField K (AlgebraicClosure K) :=
    IntermediateField.adjoin K (g.rootSet (AlgebraicClosure K))
  have hSplit_p2 : IsSplittingField K L' g := by
    refine (IntermediateField.adjoin_rootSet_isSplittingField (K:=K)
      (L:=AlgebraicClosure K) (p:=g) ?_)
    exact IsAlgClosed.splits_codomain (f := algebraMap K (AlgebraicClosure K)) g
  have hζ2 : (primitiveRoots (p^2) K).Nonempty :=
    FATEX27.primitiveRoots_p2_nonempty p hp h
  have hIrred_p2 : Irreducible (X ^ (p^2) - C a) :=
    FATEX27.irreducible_X_pow_sub_C_p2 p hp h hIrred'
  have hL_eq :
      (L : IntermediateField K (AlgebraicClosure K)) =
        IntermediateField.adjoin K ((X ^ p - C a).rootSet (AlgebraicClosure K)) := by
    have h' := (IntermediateField.isSplittingField_iff (K:=K) (L:=AlgebraicClosure K) (F:=L)
      (p:=X ^ p - C a)).1 hSplit'
    exact h'.2
  have hsubset :
      (X ^ p - C a).rootSet (AlgebraicClosure K) ⊆ (L' : Set (AlgebraicClosure K)) :=
    FATEX27.rootSet_X_pow_sub_C_subset_adjoin_rootSet_p2 p hp.pos a
  have hLle : L ≤ L' := by
    have hle' :
        IntermediateField.adjoin K ((X ^ p - C a).rootSet (AlgebraicClosure K)) ≤ L' :=
      (IntermediateField.adjoin_le_iff).2 hsubset
    simpa [hL_eq] using hle'
  let algLL' : Algebra L L' := (IntermediateField.inclusion hLle).toRingHom.toAlgebra
  have towerLL' : IsScalarTower K L L' := by
    letI : Algebra L L' := algLL'
    infer_instance
  letI : Algebra L L' := algLL'
  letI : IsScalarTower K L L' := towerLL'
  letI : IsSplittingField K L' (X ^ (p^2) - C a) := hSplit_p2
  have hGaloisKL' : IsGalois K L' :=
    isGalois_of_isSplittingField_X_pow_sub_C hζ2 hIrred_p2 L'
  letI : IsGalois K L' := hGaloisKL'
  have hGaloisLL' : IsGalois L L' :=
    IsGalois.tower_top_of_isGalois K L L'
  have hfinrank_p2 : finrank K L' = p^2 :=
    finrank_of_isSplittingField_X_pow_sub_C hζ2 hIrred_p2 L'
  haveI : FiniteDimensional K L' := by
    refine FiniteDimensional.of_finrank_pos ?_
    simpa [hfinrank_p2] using pow_pos hp.pos 2
  have hmul :
      finrank K L * finrank L L' = finrank K L' :=
    (Module.finrank_mul_finrank K L L')
  have hmul' : p * finrank L L' = p^2 := by
    simpa [hfinrank, hfinrank_p2] using hmul
  have hfinrank_LL' : finrank L L' = p := by
    have hmul'' : p * finrank L L' = p * p := by
      simpa [pow_two] using hmul'
    exact Nat.mul_left_cancel hp.pos hmul''
  haveI : Nat.AtLeastTwo p := ⟨hp.two_le⟩
  have hrank_LL' : Module.rank L L' = p := by
    exact (rank_eq_ofNat_iff_finrank_eq_ofNat (R:=L) (M:=L') p).2 hfinrank_LL'
  refine ⟨L', inferInstance, inferInstance, algLL', towerLL', ?_⟩
  exact ⟨hGaloisKL', hGaloisLL', hrank_LL'⟩
