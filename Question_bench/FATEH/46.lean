import Mathlib

open IntermediateField
open Polynomial

/-- The intermediate field generated by one element of a quadratic number field has degree
dividing `2`. -/
lemma finrank_adjoin_dvd_two {K : Type*} [Field K] [NumberField K] {a : K}
    (hk : Module.finrank ℚ K = 2) : Module.finrank ℚ ℚ⟮a⟯ ∣ 2 := by
  have hdiv : Module.finrank ℚ ℚ⟮a⟯ ∣ Module.finrank ℚ K := by
    simpa [IntermediateField.finrank_top'] using
      (IntermediateField.finrank_dvd_of_le_right
        (K:=ℚ) (L:=K) (F:=ℚ⟮a⟯) (E:=⊤) (by exact le_top))
  simpa [hk] using hdiv

/-- An algebraic extension of degree at most `2` is normal. -/
lemma normal_of_finrank_le_two {F K : Type*} [Field F] [Field K] [Algebra F K]
    [Algebra.IsAlgebraic F K] [FiniteDimensional F K]
    (h : Module.finrank F K ≤ 2) : Normal F K := by
  classical
  refine { splits' := ?_ }
  intro x
  have hdeg : (minpoly F x).natDegree ≤ 2 := (minpoly.natDegree_le x).trans h
  obtain hdeg | hdeg := lt_or_eq_of_le hdeg
  · have hle1 : (minpoly F x).natDegree ≤ 1 := by
      have : (minpoly F x).natDegree < 1 + 1 := by simpa using hdeg
      exact (Nat.lt_succ_iff.mp this)
    exact Splits.of_natDegree_le_one (natDegree_map_le.trans hle1)
  · exact splits_of_natDegree_eq_two _ hdeg (minpoly.aeval F x)

/-- A normal extension is a normal closure of itself. -/
lemma isNormalClosure_self_of_normal {F K : Type*} [Field F] [Field K] [Algebra F K]
    [Normal F K] : IsNormalClosure F K K := by
  refine (Algebra.IsAlgebraic.isNormalClosure_iff (F:=F) (K:=K) (L:=K)).2 ?_
  refine ⟨?splits, ?closure⟩
  · intro x
    simpa using (Normal.splits (inferInstance : Normal F K) x)
  · apply le_antisymm le_top
    refine le_iSup_of_le (AlgEquiv.refl : K ≃ₐ[F] K) ?_
    simpa using (le_of_eq (AlgEquiv.fieldRange_eq_top (AlgEquiv.refl : K ≃ₐ[F] K)).symm)
/--Let \( \alpha \) be a non-zero complex number such that \( \alpha + \alpha^{-1} \) is contained
in a quadratic number field. Let \( L \) be the normal closure of \( \mathbb{Q}(\alpha) \). Show
that \( [L : \mathbb{Q}] \) divides \( 8 \).-/
theorem finrank_dvd_eight_of_add_inv_eq_algebraMap {α : ℂ} {K L : Type} [Field K] [NumberField K]
    [Algebra K ℂ] (hk : Module.finrank ℚ K = 2) {a : K} (h : α + α⁻¹ = algebraMap K ℂ a)
    [Field L] [Algebra ℚ L] [IsNormalClosure ℚ ℚ⟮a⟯ L] : Module.finrank ℚ L ∣ 8 := by
  have _ := h
  have hdiv_two : Module.finrank ℚ ℚ⟮a⟯ ∣ 2 := finrank_adjoin_dvd_two (K:=K) (a:=a) hk
  have hle : Module.finrank ℚ ℚ⟮a⟯ ≤ 2 :=
    Nat.le_of_dvd (by decide : 0 < 2) hdiv_two
  have hnormal : Normal ℚ ℚ⟮a⟯ := normal_of_finrank_le_two (F:=ℚ) (K:=ℚ⟮a⟯) hle
  haveI : Normal ℚ ℚ⟮a⟯ := hnormal
  haveI : IsNormalClosure ℚ ℚ⟮a⟯ ℚ⟮a⟯ := isNormalClosure_self_of_normal (F:=ℚ) (K:=ℚ⟮a⟯)
  have hfinrank : Module.finrank ℚ L = Module.finrank ℚ ℚ⟮a⟯ := by
    simpa using (LinearEquiv.finrank_eq
      (IsNormalClosure.equiv (F:=ℚ) (K:=ℚ⟮a⟯) (L:=L) (L':=ℚ⟮a⟯)).toLinearEquiv)
  have hdivL : Module.finrank ℚ L ∣ 2 := by
    simpa [hfinrank] using hdiv_two
  exact hdivL.trans (by decide)
