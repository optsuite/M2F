import Mathlib

/- Prove that the ring $\mathbb{Z}[\sqrt{-5}]$ is not a principal ideal domain. -/

/-!
### A standard non-principal ideal in `ℤ[√-5]`

We use the classical ideal `I = (2, 1 + √-5)`:
1. `I` is proper, using a reduction map to `ZMod 2` sending `√-5 ↦ 1`.
2. If `I` were principal, generated by `a`, then `a ∣ 2` and `a ∣ (1 + √-5)`.
   A norm argument forces `a` to be a unit, hence `I = ⊤`, contradiction.
-/

namespace ZsqrtdNegFive

open Zsqrtd

/-! #### The reduction map `ℤ[√-5] → 𝔽₂` with `√-5 ↦ 1` -/

/-- The ring map `Zsqrtd (-5) →+* ZMod 2` sending `√-5` to `1`. -/
private def toZMod2 : Zsqrtd (-5) →+* ZMod 2 :=
  Zsqrtd.lift (R := ZMod 2) (d := -5) ⟨(1 : ZMod 2), by decide⟩

@[simp] private lemma toZMod2_sqrtd : toZMod2 (Zsqrtd.sqrtd (d := -5)) = 1 := by
  simp [toZMod2]

@[simp] private lemma toZMod2_two : toZMod2 (2 : Zsqrtd (-5)) = 0 := by
  simp [toZMod2]
  decide

@[simp] private lemma toZMod2_one_add_sqrtd : toZMod2 (1 + Zsqrtd.sqrtd (d := -5)) = 0 := by
  simp [toZMod2]
  decide

@[simp] private lemma toZMod2_one : toZMod2 (1 : Zsqrtd (-5)) = 1 := by
  simp [toZMod2]

/-! #### The key ideal `I = (2, 1 + √-5)` is proper -/

/-- The ideal `I = (2, 1 + √-5)` in `ℤ[√-5]`. -/
private def I : Ideal (Zsqrtd (-5)) :=
  Ideal.span ({(2 : Zsqrtd (-5)), (1 + Zsqrtd.sqrtd (d := -5))} : Set (Zsqrtd (-5)))

/-- `I = (2, 1 + √-5)` is a proper ideal. -/
private lemma I_ne_top : I ≠ ⊤ := by
  classical
  have hIker : I ≤ RingHom.ker toZMod2 := by
    refine (Ideal.span_le).2 ?_
    intro x hx
    rcases (by
      simpa [Set.mem_insert_iff, Set.mem_singleton_iff] using hx) with rfl | rfl <;>
      simp [RingHom.mem_ker]
  intro htop
  have : (1 : Zsqrtd (-5)) ∈ RingHom.ker toZMod2 := by
    have : (1 : Zsqrtd (-5)) ∈ I := by simp [htop]
    exact hIker this
  have h10 := this
  simp [RingHom.mem_ker] at h10

/-! #### A small norm lemma: `a^2 + 5b^2 ≠ 2` for integers `a,b` -/

/- In `ZMod 5`, the equation `x^2 = 2` has no solutions (finite check). -/
private lemma zmod5_sq_ne_two : ∀ x : ZMod 5, x ^ 2 ≠ (2 : ZMod 5) := by
  decide

/-- In `ℤ[√-5]`, no element has norm `2`. -/
private lemma norm_ne_two (x : Zsqrtd (-5)) : x.norm ≠ 2 := by
  rcases x with ⟨a, b⟩
  intro h
  have h' : ((a : ZMod 5) ^ 2) = (2 : ZMod 5) := by
    have := congrArg (fun n : ℤ => (n : ZMod 5)) h
    have h5 : (5 : ZMod 5) = 0 := by decide
    have : (↑a : ZMod 5) * ↑a = (2 : ZMod 5) := by
      simpa [Zsqrtd.norm, pow_two, mul_assoc, mul_left_comm, mul_comm, h5] using this
    simpa [pow_two] using this
  exact (zmod5_sq_ne_two (x := (a : ZMod 5))) h'

/-! #### If `a ∣ 2` and `a ∣ (1 + √-5)`, then `a` is a unit -/

/-- If an element divides both `2` and `1 + √-5`, then it is a unit. -/
private lemma isUnit_of_dvd_two_and_one_add_sqrtd {a : Zsqrtd (-5)}
    (ha2 : a ∣ (2 : Zsqrtd (-5))) (ha1 : a ∣ (1 + Zsqrtd.sqrtd (d := -5))) : IsUnit a := by
  have hnorm2 : a.norm ∣ (2 : ℤ) := by
    have hnorm4 : a.norm ∣ (4 : ℤ) := by
      rcases ha2 with ⟨b, hb⟩
      refine ⟨b.norm, ?_⟩
      have hb' := congrArg Zsqrtd.norm hb
      -- Rewrite `norm (a * b)` using multiplicativity before evaluating `norm (2)`.
      have hb'' : (2 : Zsqrtd (-5)).norm = a.norm * b.norm := by
        simpa [Zsqrtd.norm_mul] using hb'
      simpa using hb''
    have hnorm6 : a.norm ∣ (6 : ℤ) := by
      rcases ha1 with ⟨b, hb⟩
      refine ⟨b.norm, ?_⟩
      have hb' := congrArg Zsqrtd.norm hb
      have hb'' : (1 + Zsqrtd.sqrtd (d := -5) : Zsqrtd (-5)).norm = a.norm * b.norm := by
        simpa [Zsqrtd.norm_mul] using hb'
      simpa [Zsqrtd.norm] using hb''
    -- `a.norm` divides both `4` and `6`, hence divides `2 = 6 - 4`.
    simpa using dvd_sub hnorm6 hnorm4

  -- Move divisibility of norms into `ℕ`, where we can use primality of `2`.
  have hnat : a.norm.natAbs ∣ 2 := by
    have := (Int.natAbs_dvd_natAbs).2 hnorm2
    simpa using this
  have hcases : a.norm.natAbs = 1 ∨ a.norm.natAbs = 2 :=
    (Nat.dvd_prime Nat.prime_two).1 hnat

  have hn_nonneg : 0 ≤ a.norm := by
    simpa using (Zsqrtd.norm_nonneg (d := (-5 : ℤ)) (by decide) a)
  have hn_ne2 : a.norm.natAbs ≠ 2 := by
    intro h2
    have hn : (Int.ofNat a.norm.natAbs : ℤ) = a.norm :=
      Int.ofNat_natAbs_of_nonneg hn_nonneg
    have : a.norm = 2 := by
      -- Convert `natAbs = 2` back to an equality in `ℤ`, using nonnegativity.
      have : (Int.ofNat a.norm.natAbs : ℤ) = (2 : ℤ) := by simp [h2]
      -- `hn` identifies `a.norm` with `ofNat (natAbs a.norm)`.
      exact hn.symm.trans this
    exact norm_ne_two a this

  have hnabs1 : a.norm.natAbs = 1 := by
    rcases hcases with h1 | h2
    · exact h1
    · exact (hn_ne2 h2).elim

  exact (Zsqrtd.norm_eq_one_iff (x := a)).1 hnabs1

end ZsqrtdNegFive

theorem not_isPrincipalIdealRing_Zsqrtd_neg_five : ¬IsPrincipalIdealRing (Zsqrtd (-5)) := by
  classical
  intro h
  letI : IsPrincipalIdealRing (Zsqrtd (-5)) := h
  -- Consider the classical ideal `I = (2, 1 + √-5)`.
  let J : Ideal (Zsqrtd (-5)) := ZsqrtdNegFive.I
  have hJ_ne_top : J ≠ ⊤ := ZsqrtdNegFive.I_ne_top

  -- Since the ring is assumed principal, `J` is generated by some element `a`.
  let a : Zsqrtd (-5) := Submodule.IsPrincipal.generator J
  have hJ : Ideal.span ({a} : Set (Zsqrtd (-5))) = J := by
    dsimp [a]
    exact Ideal.span_singleton_generator (I := J)

  -- The generator divides both `2` and `1 + √-5`.
  have ha2 : a ∣ (2 : Zsqrtd (-5)) := by
    have : (2 : Zsqrtd (-5)) ∈ J := by
      -- `2` is one of the generators of `ZsqrtdNegFive.I`.
      simpa [ZsqrtdNegFive.I] using
        (Ideal.subset_span (by simp : (2 : Zsqrtd (-5)) ∈
          ({(2 : Zsqrtd (-5)), (1 + Zsqrtd.sqrtd (d := -5))} : Set (Zsqrtd (-5)))))
    have : (2 : Zsqrtd (-5)) ∈ Ideal.span ({a} : Set (Zsqrtd (-5))) := by
      -- rewrite `J` as the principal ideal generated by `a`
      simpa [hJ] using this
    exact (Ideal.mem_span_singleton.mp this)

  have ha1 : a ∣ (1 + Zsqrtd.sqrtd (d := -5) : Zsqrtd (-5)) := by
    have : (1 + Zsqrtd.sqrtd (d := -5) : Zsqrtd (-5)) ∈ J := by
      simpa [ZsqrtdNegFive.I] using
        (Ideal.subset_span (by simp : (1 + Zsqrtd.sqrtd (d := -5) : Zsqrtd (-5)) ∈
          ({(2 : Zsqrtd (-5)), (1 + Zsqrtd.sqrtd (d := -5))} : Set (Zsqrtd (-5)))))
    have : (1 + Zsqrtd.sqrtd (d := -5) : Zsqrtd (-5)) ∈ Ideal.span ({a} : Set (Zsqrtd (-5))) := by
      simpa [hJ] using this
    exact (Ideal.mem_span_singleton.mp this)

  have hau : IsUnit a := ZsqrtdNegFive.isUnit_of_dvd_two_and_one_add_sqrtd ha2 ha1
  have : J = ⊤ := by
    -- If `a` is a unit, the ideal it generates is the whole ring.
    have : Ideal.span ({a} : Set (Zsqrtd (-5))) = ⊤ :=
      (Ideal.span_singleton_eq_top).2 hau
    -- Transport along `hJ : span {a} = J`.
    simpa [hJ] using this

  exact hJ_ne_top this
