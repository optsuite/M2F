import Mathlib

open Polynomial
/- Prove that a splitting field of \( X^{15} - 2 \) over \( \mathbb{F}_7 \) is generated by a
 primitive \( 45 \)-th root of unity.-/
noncomputable section

private instance : Fact (Nat.Prime 7) := by decide

private abbrev poly : (ZMod 7)[X] := X ^ 15 - C 2

-- Count roots via separability in the splitting field.
private lemma rootSet_card_eq_15 :
    Fintype.card (poly.rootSet poly.SplittingField) = 15 := by
  classical
  have hsep : poly.Separable := by
    have h15 : (15 : ZMod 7) ≠ 0 := by decide
    have h2 : (2 : ZMod 7) ≠ 0 := by decide
    simpa [poly] using (separable_X_pow_sub_C (a := (2 : ZMod 7)) h15 h2)
  have hsplit : Splits (poly.map (algebraMap (ZMod 7) poly.SplittingField)) := by
    simpa [poly] using (SplittingField.splits (f := poly))
  have hcard := card_rootSet_eq_natDegree (K := poly.SplittingField) hsep hsplit
  simpa [poly, natDegree_X_pow_sub_C] using hcard

-- Extract a primitive 15th root of unity from the root set.
private lemma exists_primitiveRoot_15 :
    ∃ η : poly.SplittingField, IsPrimitiveRoot η 15 := by
  classical
  let L := poly.SplittingField
  have hcard : Fintype.card (poly.rootSet L) = 15 := rootSet_card_eq_15
  have hnonempty : Nonempty (poly.rootSet L) := by
    have : 0 < Fintype.card (poly.rootSet L) := by
      simp [hcard]
    exact Fintype.card_pos_iff.mp this
  obtain ⟨α⟩ := hnonempty
  have hrootPow : ∀ r : poly.rootSet L, (r : L) ^ 15 = algebraMap (ZMod 7) L 2 := by
    intro r
    have hroot : aeval (r : L) poly = 0 := aeval_eq_zero_of_mem_rootSet r.property
    have hroot' : (r : L) ^ 15 - algebraMap (ZMod 7) L 2 = 0 := by
      simpa [poly, aeval_X_pow, aeval_C] using hroot
    exact sub_eq_zero.mp hroot'
  have hαpow : (α : L) ^ 15 = algebraMap (ZMod 7) L 2 := hrootPow α
  have h2ne : algebraMap (ZMod 7) L (2 : ZMod 7) ≠ 0 := by
    simpa using (by decide : (2 : ZMod 7) ≠ 0)
  have hαne : (α : L) ≠ 0 := by
    intro hzero
    have : algebraMap (ZMod 7) L (2 : ZMod 7) = 0 := by
      simpa [hzero, eq_comm] using hαpow
    exact h2ne this
  have hle : 15 ≤ Fintype.card (rootsOfUnity 15 L) := by
    haveI : NeZero (15 : ℕ) := ⟨by decide⟩
    let φ : poly.rootSet L → rootsOfUnity 15 L := fun r =>
      rootsOfUnity.mkOfPowEq (r / (α : L)) (by
        have hrpow := hrootPow r
        have hαpow := hαpow
        simp [div_pow, hrpow, hαpow, h2ne])
    have hφinj : Function.Injective φ := by
      intro r1 r2 h
      have hval_units : (φ r1 : Lˣ) = (φ r2 : Lˣ) := congrArg Subtype.val h
      have hval : (r1 : L) / (α : L) = (r2 : L) / (α : L) := by
        simpa [φ, rootsOfUnity.coe_mkOfPowEq] using (Units.ext_iff.mp hval_units)
      have hval' : (r1 : L) = (r2 : L) := by
        simpa [div_eq_mul_inv, hαne] using congrArg (fun x => x * (α : L)) hval
      exact Subtype.ext hval'
    have hcard_le :
        Fintype.card (poly.rootSet L) ≤ Fintype.card (rootsOfUnity 15 L) :=
      Fintype.card_le_of_injective φ hφinj
    simpa [hcard] using hcard_le
  have hcard_roots : Fintype.card (rootsOfUnity 15 L) = 15 :=
    le_antisymm (card_rootsOfUnity (R := L) (k := 15)) hle
  haveI : NeZero (15 : ℕ) := ⟨by decide⟩
  exact (card_rootsOfUnity_eq_iff_exists_isPrimitiveRoot (R := L) (n := 15)).1 hcard_roots

-- Combine primitive 9th and 5th roots to get a primitive 45th root.
private lemma exists_primitiveRoot_45 :
    ∃ ζ : poly.SplittingField, IsPrimitiveRoot ζ 45 := by
  classical
  let L := poly.SplittingField
  have hcard : Fintype.card (poly.rootSet L) = 15 := rootSet_card_eq_15
  have hnonempty : Nonempty (poly.rootSet L) := by
    have : 0 < Fintype.card (poly.rootSet L) := by
      simp [hcard]
    exact Fintype.card_pos_iff.mp this
  obtain ⟨α⟩ := hnonempty
  have hαpow : (α : L) ^ 15 = algebraMap (ZMod 7) L 2 := by
    have hroot : aeval (α : L) poly = 0 := aeval_eq_zero_of_mem_rootSet α.property
    have hroot' : (α : L) ^ 15 - algebraMap (ZMod 7) L 2 = 0 := by
      simpa [poly, aeval_X_pow, aeval_C] using hroot
    exact sub_eq_zero.mp hroot'
  have h2pow : (algebraMap (ZMod 7) L (2 : ZMod 7)) ^ 3 = (1 : L) := by
    have h2 : (2 : ZMod 7) ^ 3 = 1 := by decide
    simpa using congrArg (algebraMap (ZMod 7) L) h2
  have h2ne : algebraMap (ZMod 7) L (2 : ZMod 7) ≠ (1 : L) := by
    intro h
    have h' : (2 : ZMod 7) = 1 :=
      (FaithfulSMul.algebraMap_eq_one_iff (R := ZMod 7) (A := L)).1 h
    exact (by decide : (2 : ZMod 7) ≠ 1) h'
  have hα5_pow3 : ((α : L) ^ 5) ^ 3 = algebraMap (ZMod 7) L 2 := by
    calc
      ((α : L) ^ 5) ^ 3 = (α : L) ^ (5 * 3) := by
        simpa using (pow_mul (α : L) 5 3).symm
      _ = (α : L) ^ 15 := by
        simp [show (5 * 3 : ℕ) = 15 by decide]
      _ = algebraMap (ZMod 7) L 2 := hαpow
  have hα45 : (α : L) ^ 45 = 1 := by
    have h45 : (45 : ℕ) = 15 * 3 := by decide
    calc
      (α : L) ^ 45 = (α : L) ^ (15 * 3) := by simp [h45]
      _ = ((α : L) ^ 15) ^ 3 := by simpa using (pow_mul (α : L) 15 3)
      _ = 1 := by simp [hαpow, h2pow]
  have hα5_pow9 : ((α : L) ^ 5) ^ 9 = 1 := by
    have h45' : (5 * 9 : ℕ) = 45 := by decide
    calc
      ((α : L) ^ 5) ^ 9 = (α : L) ^ (5 * 9) := by
        simpa using (pow_mul (α : L) 5 9).symm
      _ = (α : L) ^ 45 := by simp [h45']
      _ = 1 := hα45
  have hdiv : orderOf ((α : L) ^ 5) ∣ 9 :=
    (orderOf_dvd_iff_pow_eq_one).2 hα5_pow9
  have hnot : ¬ orderOf ((α : L) ^ 5) ∣ 3 := by
    intro hdiv3
    have hpow3 : ((α : L) ^ 5) ^ 3 = 1 :=
      (orderOf_dvd_iff_pow_eq_one).1 hdiv3
    exact h2ne (by simpa [hα5_pow3] using hpow3)
  have horder : orderOf ((α : L) ^ 5) = 9 := by
    have hdiv' : orderOf ((α : L) ^ 5) ∣ 3 ^ (2 : ℕ) := by
      simpa [show (9 : ℕ) = 3 ^ (2 : ℕ) by decide] using hdiv
    obtain ⟨k, hk, hkpow⟩ := (Nat.dvd_prime_pow (by decide : Nat.Prime 3)).1 hdiv'
    cases k with
    | zero =>
      have : orderOf ((α : L) ^ 5) ∣ 3 := by simp [hkpow]
      exact (hnot this).elim
    | succ k =>
      cases k with
      | zero =>
        have : orderOf ((α : L) ^ 5) ∣ 3 := by simp [hkpow]
        exact (hnot this).elim
      | succ k =>
        have hk' : k.succ ≤ 1 := Nat.succ_le_succ_iff.mp hk
        have hk'' : k ≤ 0 := Nat.succ_le_succ_iff.mp hk'
        have hk0 : k = 0 := Nat.eq_zero_of_le_zero hk''
        simpa [hk0] using hkpow
  have hβ : IsPrimitiveRoot ((α : L) ^ 5) 9 :=
    (IsPrimitiveRoot.iff_orderOf).2 horder
  obtain ⟨η, hη⟩ := exists_primitiveRoot_15
  have hη5 : IsPrimitiveRoot (η ^ 3) 5 := by
    have hdiv' : (3 : ℕ) ∣ 15 := by decide
    have h3ne : (3 : ℕ) ≠ 0 := by decide
    simpa using (IsPrimitiveRoot.pow_of_dvd hη (p := 3) h3ne hdiv')
  have hζ :
      IsPrimitiveRoot
        (((α : L) ^ 5) ^ (9 / Nat.factorizationLCMLeft 9 5) *
          (η ^ 3) ^ (5 / Nat.factorizationLCMRight 9 5))
        (Nat.lcm 9 5) :=
    IsPrimitiveRoot.pow_mul_pow_lcm hβ hη5 (by decide) (by decide)
  have h45 : Nat.lcm 9 5 = 45 := by decide
  refine
    ⟨((α : L) ^ 5) ^ (9 / Nat.factorizationLCMLeft 9 5) *
        (η ^ 3) ^ (5 / Nat.factorizationLCMRight 9 5), ?_⟩
  simpa [h45] using hζ

theorem exists_isPrimitiveRoot_and_adjoin_eq_top :
    letI : Fact (Nat.Prime 7) := by decide
    ∃ ζ : (X ^ 15 - 2 : (ZMod 7)[X]).SplittingField, IsPrimitiveRoot ζ 45 ∧
    IntermediateField.adjoin (ZMod 7) {ζ} = ⊤ := by
  classical
  let L := poly.SplittingField
  obtain ⟨ζ, hζ⟩ := exists_primitiveRoot_45
  refine ⟨ζ, hζ, ?_⟩
  have hrootPow : ∀ {r : L}, r ∈ poly.rootSet L → r ^ 15 = algebraMap (ZMod 7) L 2 := by
    intro r hr
    have hroot : aeval r poly = 0 := aeval_eq_zero_of_mem_rootSet hr
    have hroot' : r ^ 15 - algebraMap (ZMod 7) L 2 = 0 := by
      simpa [poly, aeval_X_pow, aeval_C] using hroot
    exact sub_eq_zero.mp hroot'
  have h2pow : (algebraMap (ZMod 7) L (2 : ZMod 7)) ^ 3 = (1 : L) := by
    have h2 : (2 : ZMod 7) ^ 3 = 1 := by decide
    simpa using congrArg (algebraMap (ZMod 7) L) h2
  have hsubset : poly.rootSet L ⊆ Algebra.adjoin (ZMod 7) ({ζ} : Set L) := by
    intro r hr
    have hr15 : r ^ 15 = algebraMap (ZMod 7) L 2 := hrootPow hr
    have hr45 : r ^ 45 = 1 := by
      have h45 : (45 : ℕ) = 15 * 3 := by decide
      calc
        r ^ 45 = r ^ (15 * 3) := by simp [h45]
        _ = (r ^ 15) ^ 3 := by simpa using (pow_mul r 15 3)
        _ = 1 := by simp [hr15, h2pow]
    haveI : NeZero (45 : ℕ) := ⟨by decide⟩
    obtain ⟨i, _, rfl⟩ := hζ.eq_pow_of_pow_eq_one hr45
    exact Subalgebra.pow_mem _ (Algebra.subset_adjoin (by simp)) _
  have htop : Algebra.adjoin (ZMod 7) (poly.rootSet L) = ⊤ := by
    simpa [poly] using (SplittingField.adjoin_rootSet (f := poly))
  have hle : ⊤ ≤ Algebra.adjoin (ZMod 7) ({ζ} : Set L) := by
    have hle' :
        Algebra.adjoin (ZMod 7) (poly.rootSet L) ≤
          Algebra.adjoin (ZMod 7) ({ζ} : Set L) :=
      Algebra.adjoin_le hsubset
    calc
      (⊤ : Subalgebra (ZMod 7) L) = Algebra.adjoin (ZMod 7) (poly.rootSet L) := htop.symm
      _ ≤ Algebra.adjoin (ZMod 7) ({ζ} : Set L) := hle'
  have htop' : Algebra.adjoin (ZMod 7) ({ζ} : Set L) = ⊤ :=
    le_antisymm le_top hle
  exact
    IntermediateField.adjoin_eq_top_of_algebra (F := ZMod 7) (E := L) (S := {ζ}) htop'

end
