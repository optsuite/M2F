import Mathlib

open IntermediateField Polynomial
open RatFunc
open scoped Polynomial.Bivariate
open scoped nonZeroDivisors

-- The rational function field is generated by the indeterminate over the base field.
lemma ratfunc_adjoin_X_eq_top (F : Type) [Field F] :
    (IntermediateField.adjoin F ({RatFunc.X} : Set (RatFunc F))) = ⊤ := by
  classical
  apply top_le_iff.mp
  intro x hx
  refine RatFunc.induction_on x ?_
  intro p q hq
  set K : IntermediateField F (RatFunc F) :=
    IntermediateField.adjoin F ({RatFunc.X} : Set (RatFunc F))
  have hp : algebraMap F[X] (RatFunc F) p ∈ K := by
    have hp' :
        (Polynomial.aeval (RatFunc.X : RatFunc F) p) ∈
          Algebra.adjoin F ({RatFunc.X} : Set (RatFunc F)) := by
      simpa using
        (Polynomial.aeval_mem_adjoin_singleton (R := F) (x := (RatFunc.X : RatFunc F)) (p := p))
    have hp'' :
        (Polynomial.aeval (RatFunc.X : RatFunc F) p) ∈ K := by
      exact
        (IntermediateField.algebra_adjoin_le_adjoin (F := F)
            ({RatFunc.X} : Set (RatFunc F))) hp'
    simpa [RatFunc.aeval_X_left_eq_algebraMap] using hp''
  have hq' : algebraMap F[X] (RatFunc F) q ∈ K := by
    have hq' :
        (Polynomial.aeval (RatFunc.X : RatFunc F) q) ∈
          Algebra.adjoin F ({RatFunc.X} : Set (RatFunc F)) := by
      simpa using
        (Polynomial.aeval_mem_adjoin_singleton (R := F) (x := (RatFunc.X : RatFunc F)) (p := q))
    have hq'' :
        (Polynomial.aeval (RatFunc.X : RatFunc F) q) ∈ K := by
      exact
        (IntermediateField.algebra_adjoin_le_adjoin (F := F)
            ({RatFunc.X} : Set (RatFunc F))) hq'
    simpa [RatFunc.aeval_X_left_eq_algebraMap] using hq''
  exact K.div_mem hp hq'

-- Over any intermediate field containing `F`, `RatFunc.X` still generates all of `RatFunc F`.
lemma ratfunc_adjoin_X_eq_top_over_K (F : Type) [Field F] (f g : F[X]) :
    let t : RatFunc F := (f : RatFunc F) / g
    let K : IntermediateField F (RatFunc F) := F⟮t⟯
    IntermediateField.adjoin K ({RatFunc.X} : Set (RatFunc F)) = ⊤ := by
  classical
  intro t K
  simpa using
    (IntermediateField.adjoin_eq_top_of_adjoin_eq_top (F := F) (E := K) (K := RatFunc F)
      (S := ({RatFunc.X} : Set (RatFunc F))) (hprim := ratfunc_adjoin_X_eq_top F))

-- The polynomial relation `f - t * g` vanishes at `RatFunc.X`.
lemma ratfunc_relation_poly_aeval (F : Type) [Field F] (f g : F[X]) (hg : g ≠ 0) :
    let t : RatFunc F := (f : RatFunc F) / g
    let K : IntermediateField F (RatFunc F) := F⟮t⟯
    let tK : K := ⟨t, by
      -- `t` is in the adjoin by construction.
      have ht : t ∈ IntermediateField.adjoin F ({t} : Set (RatFunc F)) :=
        (IntermediateField.subset_adjoin (F := F) ({t} : Set (RatFunc F))) (by simp)
      simpa [K] using ht⟩
    let p : K[X] :=
      Polynomial.map (algebraMap F K) f - Polynomial.C tK * Polynomial.map (algebraMap F K) g
    Polynomial.aeval (RatFunc.X : RatFunc F) p = 0 := by
  classical
  intro t K tK p
  -- Evaluate term-by-term and use `t = f/g`.
  have hmap_f :
      Polynomial.aeval (RatFunc.X : RatFunc F) (Polynomial.map (algebraMap F K) f) =
        algebraMap F[X] (RatFunc F) f := by
    simp [RatFunc.aeval_X_left_eq_algebraMap]
  have hmap_g :
      Polynomial.aeval (RatFunc.X : RatFunc F) (Polynomial.map (algebraMap F K) g) =
        algebraMap F[X] (RatFunc F) g := by
    simp [RatFunc.aeval_X_left_eq_algebraMap]
  have htK : (tK : RatFunc F) = t := rfl
  calc
    Polynomial.aeval (RatFunc.X : RatFunc F) p
        = algebraMap F[X] (RatFunc F) f - (tK : RatFunc F) * algebraMap F[X] (RatFunc F) g := by
            simp [p, hmap_f, hmap_g, aeval_mul, aeval_sub, aeval_C]
    _ = (f : RatFunc F) - (t : RatFunc F) * g := by
          rfl
    _ = 0 := by
          have hg' : (g : RatFunc F) ≠ 0 := by
            intro h
            apply hg
            have h' : algebraMap F[X] (RatFunc F) g = 0 := by
              exact h
            have hnum :
                RatFunc.num (algebraMap F[X] (RatFunc F) g) = 0 := by
              exact (RatFunc.num_eq_zero_iff (x := algebraMap F[X] (RatFunc F) g)).2 h'
            simpa [RatFunc.num_algebraMap] using hnum
          calc
            (f : RatFunc F) - (t : RatFunc F) * g
                = (f : RatFunc F) - ((f : RatFunc F) / g) * g := by rfl
            _ = (f : RatFunc F) - (f : RatFunc F) := by
                  simp [hg']
            _ = 0 := by simp

-- A nonconstant rational function `f/g` cannot be a constant in `RatFunc F`.
lemma ratfunc_div_not_constant (F : Type) [Field F] (f g : F[X]) (hf : f ≠ 0) (hg : g ≠ 0)
    (hcoprime : IsCoprime f g) (hfg : ¬(f.natDegree = 0 ∧ g.natDegree = 0)) :
    let t : RatFunc F := (f : RatFunc F) / g
    ∀ c : F, t ≠ RatFunc.C c := by
  classical
  intro t c hc
  have h_eq :
      RatFunc.C c = algebraMap F[X] (RatFunc F) f / algebraMap F[X] (RatFunc F) g := by
    simpa [t] using hc.symm
  have h_mul :
      (RatFunc.C c).num * g = f * (RatFunc.C c).denom :=
    (RatFunc.num_mul_eq_mul_denom_iff (K := F) (x := RatFunc.C c) (p := f) (q := g) hg).2 h_eq
  have hfg' : f = Polynomial.C c * g := by
    simpa [RatFunc.num_C, RatFunc.denom_C, mul_comm, mul_left_comm, mul_assoc] using h_mul.symm
  have hunit_g : IsUnit g := hcoprime.symm.isUnit_of_dvd <| by
    refine ⟨Polynomial.C c, ?_⟩
    simp [hfg', mul_comm]
  have hdeg_g : g.natDegree = 0 := by
    exact Polynomial.natDegree_eq_zero_of_isUnit hunit_g
  have hc0 : (c : F) ≠ 0 := by
    intro hc0
    apply hf
    calc
      f = Polynomial.C c * g := hfg'
      _ = 0 := by simp [hc0]
  have hdeg_f : f.natDegree = g.natDegree := by
    simpa [hfg'] using (Polynomial.natDegree_C_mul (p := g) (a0 := hc0) (a := c))
  exact hfg ⟨hdeg_f.trans hdeg_g, hdeg_g⟩

-- The relation polynomial `f - t*g` has degree `max (deg f) (deg g)`.
lemma ratfunc_relation_poly_natDegree (F : Type) [Field F] (f g : F[X]) (hf : f ≠ 0) (hg : g ≠ 0)
    (hcoprime : IsCoprime f g) (hfg : ¬(f.natDegree = 0 ∧ g.natDegree = 0)) :
    let t : RatFunc F := (f : RatFunc F) / g
    let K : IntermediateField F (RatFunc F) := F⟮t⟯
    let tK : K := ⟨t, by
      -- `t` is in the adjoin by construction.
      have ht : t ∈ IntermediateField.adjoin F ({t} : Set (RatFunc F)) :=
        (IntermediateField.subset_adjoin (F := F) ({t} : Set (RatFunc F))) (by simp)
      simpa [K] using ht⟩
    let p : K[X] :=
      Polynomial.map (algebraMap F K) f - Polynomial.C tK * Polynomial.map (algebraMap F K) g
    p.natDegree = max f.natDegree g.natDegree := by
  classical
  intro t K tK p
  have ht : (t : RatFunc F) ≠ 0 := by
    intro ht0
    have hdiv :
        (f : RatFunc F) = 0 ∨ (g : RatFunc F) = 0 := by
      have ht0' : (f : RatFunc F) / g = 0 := by
        simpa [t] using ht0
      exact
        (div_eq_zero_iff :
          ((f : RatFunc F) / g = 0) ↔ (f : RatFunc F) = 0 ∨ (g : RatFunc F) = 0).1 ht0'
    cases hdiv with
    | inl hf0 =>
        exact (RatFunc.algebraMap_ne_zero (K := F) hf) hf0
    | inr hg0 =>
        exact (RatFunc.algebraMap_ne_zero (K := F) hg) hg0
  have htK' : (tK : K) ≠ 0 := by
    intro h0
    apply ht
    have ht0' : (tK : RatFunc F) = 0 :=
      congrArg (fun x : K => (x : RatFunc F)) h0
    simpa [tK] using ht0'
  have hdeg_f :
      (Polynomial.map (algebraMap F K) f).natDegree = f.natDegree := by
    exact (Polynomial.natDegree_map (p := f) (f := algebraMap F K))
  have hdeg_g :
      (Polynomial.map (algebraMap F K) g).natDegree = g.natDegree := by
    exact (Polynomial.natDegree_map (p := g) (f := algebraMap F K))
  have hdeg_g' :
      (Polynomial.C tK * Polynomial.map (algebraMap F K) g).natDegree =
        (Polynomial.map (algebraMap F K) g).natDegree := by
    simpa using
      (Polynomial.natDegree_C_mul (p := Polynomial.map (algebraMap F K) g) (a0 := htK'))
  rcases lt_trichotomy f.natDegree g.natDegree with hlt | hEq | hgt
  · have hlt' :
        (Polynomial.map (algebraMap F K) f).natDegree <
          (Polynomial.C tK * Polynomial.map (algebraMap F K) g).natDegree := by
      simpa [hdeg_f, hdeg_g', hdeg_g] using hlt
    have hnat :
        p.natDegree =
          (Polynomial.C tK * Polynomial.map (algebraMap F K) g).natDegree := by
      simpa [p] using (Polynomial.natDegree_sub_eq_right_of_natDegree_lt hlt')
    have hmax : max f.natDegree g.natDegree = g.natDegree := max_eq_right (le_of_lt hlt)
    simpa [hmax, hdeg_g', hdeg_g] using hnat
  · have hmax : max f.natDegree g.natDegree = f.natDegree := by
      simp [hEq]
    have hle1 :
        (Polynomial.map (algebraMap F K) f).natDegree ≤ f.natDegree := by
      simp [hdeg_f]
    have hle2 :
        (Polynomial.C tK * Polynomial.map (algebraMap F K) g).natDegree ≤ f.natDegree := by
      have hdeg :
          (Polynomial.C tK * Polynomial.map (algebraMap F K) g).natDegree = g.natDegree := by
        simp [hdeg_g', hdeg_g]
      simp [hEq, hdeg]
    have hle :
        p.natDegree ≤ f.natDegree := by
      have hle' :=
        Polynomial.natDegree_sub_le_of_le
          (p := Polynomial.map (algebraMap F K) f)
          (q := Polynomial.C tK * Polynomial.map (algebraMap F K) g)
          (m := f.natDegree) (n := f.natDegree) hle1 hle2
      simpa [p] using hle'
    have hcoefff : f.coeff f.natDegree = f.leadingCoeff := by
      exact (Polynomial.coeff_natDegree (p := f))
    have hcoeffg : g.coeff f.natDegree = g.leadingCoeff := by
      calc
        g.coeff f.natDegree = g.coeff g.natDegree := by simp [hEq]
        _ = g.leadingCoeff := Polynomial.coeff_natDegree (p := g)
    have hcoeff :
        p.coeff f.natDegree =
          algebraMap F K f.leadingCoeff - tK * algebraMap F K g.leadingCoeff := by
      simp [p, coeff_sub, coeff_map, coeff_C_mul, hcoefff, hcoeffg]
    have hcoeff_ne : p.coeff f.natDegree ≠ 0 := by
      intro h0
      have h0' :
          algebraMap F K f.leadingCoeff =
            tK * algebraMap F K g.leadingCoeff := by
        have h0'' :
            algebraMap F K f.leadingCoeff - tK * algebraMap F K g.leadingCoeff = 0 := by
          simpa [hcoeff] using h0
        exact sub_eq_zero.mp h0''
      have hlg :
          algebraMap F K g.leadingCoeff ≠ 0 := by
        exact
          (map_ne_zero (algebraMap F K) (a := g.leadingCoeff)).2
            ((Polynomial.leadingCoeff_ne_zero).2 hg)
      have htK_eq :
          tK = algebraMap F K f.leadingCoeff / algebraMap F K g.leadingCoeff := by
        have h0'' :
            tK * algebraMap F K g.leadingCoeff = algebraMap F K f.leadingCoeff := by
          simpa [eq_comm] using h0'
        exact (eq_div_iff hlg).2 h0''
      have htK_eq' :
          tK = algebraMap F K (f.leadingCoeff / g.leadingCoeff) := by
        simpa [map_div₀] using htK_eq
      have hcomp :
          ((algebraMap F K (f.leadingCoeff / g.leadingCoeff) : K) : RatFunc F) =
            algebraMap F (RatFunc F) (f.leadingCoeff / g.leadingCoeff) := by
        have hcomp' :=
          congrArg (fun φ => φ (f.leadingCoeff / g.leadingCoeff))
            (IsScalarTower.algebraMap_eq F K (RatFunc F))
        exact hcomp'.symm
      have htK_eq'' :
          (tK : RatFunc F) =
            algebraMap F (RatFunc F) (f.leadingCoeff / g.leadingCoeff) := by
        calc
          (tK : RatFunc F)
              = ((algebraMap F K (f.leadingCoeff / g.leadingCoeff) : K) : RatFunc F) := by
                  simp [htK_eq']
          _ = algebraMap F (RatFunc F) (f.leadingCoeff / g.leadingCoeff) := hcomp
      have ht_const :
          t = RatFunc.C (f.leadingCoeff / g.leadingCoeff) := by
        simpa [RatFunc.algebraMap_eq_C] using htK_eq''
      exact (ratfunc_div_not_constant F f g hf hg hcoprime hfg _ ht_const).elim
    have hle' : f.natDegree ≤ p.natDegree := by
      exact Polynomial.le_natDegree_of_ne_zero hcoeff_ne
    have hdeg : p.natDegree = f.natDegree := le_antisymm hle hle'
    simp [hmax, hdeg]
  · have hgt' :
        (Polynomial.C tK * Polynomial.map (algebraMap F K) g).natDegree <
          (Polynomial.map (algebraMap F K) f).natDegree := by
      simpa [hdeg_f, hdeg_g', hdeg_g] using hgt
    have hnat :
        p.natDegree =
          (Polynomial.map (algebraMap F K) f).natDegree := by
      simpa [p] using (Polynomial.natDegree_sub_eq_left_of_natDegree_lt hgt')
    have hmax : max f.natDegree g.natDegree = f.natDegree := max_eq_left (le_of_lt hgt)
    simpa [hmax, hdeg_f] using hnat

-- A primitive linear polynomial in `Y` with coprime coefficients.
lemma relation_poly_primitive (F : Type) [Field F] (f g : F[X]) (hcoprime : IsCoprime f g) :
    (Polynomial.C f - (Y : (Polynomial F)[X]) * Polynomial.C g :
      (Polynomial F)[X]).IsPrimitive := by
  classical
  refine (Polynomial.isPrimitive_iff_isUnit_of_C_dvd).2 ?_
  intro r hr
  have hcoeff :=
    (Polynomial.C_dvd_iff_dvd_coeff (R := Polynomial F)
        (r := r)
        (φ := (Polynomial.C f - (Y : (Polynomial F)[X]) * Polynomial.C g : (Polynomial F)[X]))).1 hr
  have h0 : r ∣ f := by
    have :
        r ∣
          (Polynomial.C f - (Y : (Polynomial F)[X]) * Polynomial.C g :
            (Polynomial F)[X]).coeff 0 :=
      hcoeff 0
    simpa using this
  have h1 : r ∣ g := by
    have :
        r ∣
          (Polynomial.C f - (Y : (Polynomial F)[X]) * Polynomial.C g :
            (Polynomial F)[X]).coeff 1 :=
      hcoeff 1
    simpa using this
  exact hcoprime.isUnit_of_dvd' h0 h1

-- The linear relation in `Y` stays irreducible over the fraction field.
lemma relation_poly_irreducible_over_fraction (F : Type) [Field F] (f g : F[X]) (hg : g ≠ 0) :
    let q : (Polynomial F)[X] :=
      Polynomial.C f - (Y : (Polynomial F)[X]) * Polynomial.C g
    Irreducible (q.map (algebraMap (F[X]) (RatFunc F))) := by
  classical
  intro q
  have hne : algebraMap F[X] (RatFunc F) g ≠ 0 := by
    exact RatFunc.algebraMap_ne_zero (K := F) hg
  have hdeg : (q.map (algebraMap (F[X]) (RatFunc F))).degree = 1 := by
    have hne' : (-algebraMap F[X] (RatFunc F) g) ≠ 0 := by
      simpa using hne
    have hrew :
        q.map (algebraMap (F[X]) (RatFunc F)) =
          Polynomial.C (-algebraMap F[X] (RatFunc F) g) * Polynomial.X +
            Polynomial.C (algebraMap F[X] (RatFunc F) f) := by
      -- rearrange to a linear polynomial in `X`
      simp [q, sub_eq_add_neg]; ring
    simpa [hrew] using
      (Polynomial.degree_linear (a := -algebraMap F[X] (RatFunc F) g)
        (b := algebraMap F[X] (RatFunc F) f) hne')
  exact Polynomial.irreducible_of_degree_eq_one hdeg

lemma relation_poly_irreducible_over_FXY (F : Type) [Field F] (f g : F[X])
    (hg : g ≠ 0) (hcoprime : IsCoprime f g) :
    let q : (Polynomial F)[X] :=
      Polynomial.C f - (Y : (Polynomial F)[X]) * Polynomial.C g
    Irreducible q := by
  classical
  intro q
  have hprim : q.IsPrimitive := relation_poly_primitive F f g hcoprime
  have hmap :
      Irreducible (q.map (algebraMap (F[X]) (RatFunc F))) :=
    relation_poly_irreducible_over_fraction F f g hg
  exact (Polynomial.IsPrimitive.irreducible_iff_irreducible_map_fraction_map (R := F[X])
      (K := RatFunc F) hprim).2 hmap

-- Upper bound on the minpoly degree using the explicit relation polynomial.
lemma minpoly_X_natDegree_le_max (F : Type) [Field F] (f g : F[X]) (hf : f ≠ 0) (hg : g ≠ 0)
    (hcoprime : IsCoprime f g) (hfg : ¬(f.natDegree = 0 ∧ g.natDegree = 0)) :
    let t : RatFunc F := (f : RatFunc F) / g
    let K : IntermediateField F (RatFunc F) := F⟮t⟯
    (minpoly K (RatFunc.X : RatFunc F)).natDegree ≤ max f.natDegree g.natDegree := by
  classical
  intro t K
  let tK : K := ⟨t, by
      have ht : t ∈ IntermediateField.adjoin F ({t} : Set (RatFunc F)) :=
        (IntermediateField.subset_adjoin (F := F) ({t} : Set (RatFunc F))) (by simp)
      simpa [K] using ht⟩
  let p : K[X] :=
    Polynomial.map (algebraMap F K) f - Polynomial.C tK * Polynomial.map (algebraMap F K) g
  have hroot :
      Polynomial.aeval (RatFunc.X : RatFunc F) p = 0 :=
    ratfunc_relation_poly_aeval F f g hg
  have hdeg :
      p.natDegree = max f.natDegree g.natDegree :=
    ratfunc_relation_poly_natDegree F f g hf hg hcoprime hfg
  have hp_ne : p ≠ 0 := by
    have hmax_ne : max f.natDegree g.natDegree ≠ 0 := by
      intro hmax0
      have hf0 : f.natDegree = 0 := by
        have : f.natDegree ≤ max f.natDegree g.natDegree := le_max_left _ _
        exact le_antisymm (this.trans (le_of_eq hmax0)) (Nat.zero_le _)
      have hg0 : g.natDegree = 0 := by
        have : g.natDegree ≤ max f.natDegree g.natDegree := le_max_right _ _
        exact le_antisymm (this.trans (le_of_eq hmax0)) (Nat.zero_le _)
      exact hfg ⟨hf0, hg0⟩
    exact fun hp0 =>
      hmax_ne <| by
        have hp0' : p.natDegree = 0 := by
          simp [hp0]
        calc
          max f.natDegree g.natDegree = p.natDegree := by simp [hdeg]
          _ = 0 := hp0'
  have hmin_dvd : minpoly K (RatFunc.X : RatFunc F) ∣ p :=
    minpoly.dvd K (RatFunc.X : RatFunc F) hroot
  have hdeg_le := natDegree_le_of_dvd hmin_dvd hp_ne
  simpa [hdeg] using hdeg_le

/-- Let $F$ be a field, and let $f, g \in F[x] \setminus \{0\}$ be relatively prime and not both
constant. Show that $F(x)$ has finite degree $d = \max(\deg(f), \deg(g))$ over its subfield $F\left
(\frac{f}{g}\right)$. -/
theorem finrank_adjoin_dvd_eq_max_natDegree (F : Type) [Field F] (f g : F[X]) (hf : f ≠ 0)
    (hg : g ≠ 0) (hcoprime : IsCoprime f g) (hfg : ¬(f.natDegree = 0 ∧ g.natDegree = 0)) :
    Module.finrank F⟮(f : RatFunc F) / g⟯ (RatFunc F) = max f.natDegree g.natDegree := by
  classical
  let t : RatFunc F := (f : RatFunc F) / g
  let K : IntermediateField F (RatFunc F) := F⟮t⟯
  have htop : IntermediateField.adjoin K ({RatFunc.X} : Set (RatFunc F)) = ⊤ :=
    ratfunc_adjoin_X_eq_top_over_K F f g
  let tK : K := ⟨t, by
      have ht : t ∈ IntermediateField.adjoin F ({t} : Set (RatFunc F)) :=
        (IntermediateField.subset_adjoin (F := F) ({t} : Set (RatFunc F))) (by simp)
      simpa [K] using ht⟩
  let p : K[X] :=
    Polynomial.map (algebraMap F K) f - Polynomial.C tK * Polynomial.map (algebraMap F K) g
  have hroot :
      Polynomial.aeval (RatFunc.X : RatFunc F) p = 0 :=
    ratfunc_relation_poly_aeval F f g hg
  have hdeg :
      p.natDegree = max f.natDegree g.natDegree :=
    ratfunc_relation_poly_natDegree F f g hf hg hcoprime hfg
  have hInt : IsIntegral K (RatFunc.X : RatFunc F) := by
    have hp_ne : p ≠ 0 := by
      have hmax_ne : max f.natDegree g.natDegree ≠ 0 := by
        intro hmax0
        have hf0 : f.natDegree = 0 := by
          have : f.natDegree ≤ max f.natDegree g.natDegree := le_max_left _ _
          exact le_antisymm (this.trans (le_of_eq hmax0)) (Nat.zero_le _)
        have hg0 : g.natDegree = 0 := by
          have : g.natDegree ≤ max f.natDegree g.natDegree := le_max_right _ _
          exact le_antisymm (this.trans (le_of_eq hmax0)) (Nat.zero_le _)
        exact hfg ⟨hf0, hg0⟩
      exact fun hp0 =>
        hmax_ne <| by
          have hp0' : p.natDegree = 0 := by
            simp [hp0]
          calc
            max f.natDegree g.natDegree = p.natDegree := by simp [hdeg]
            _ = 0 := hp0'
    have hmonic :
        (p * Polynomial.C (p.leadingCoeff)⁻¹).Monic := by
      refine Polynomial.monic_mul_C_of_leadingCoeff_mul_eq_one ?_
      field_simp [Polynomial.leadingCoeff_ne_zero.2 hp_ne]
    refine ⟨p * Polynomial.C (p.leadingCoeff)⁻¹, hmonic, ?_⟩
    -- The relation polynomial annihilates `RatFunc.X`.
    have hroot' :
        Polynomial.aeval (RatFunc.X : RatFunc F)
          (p * Polynomial.C (p.leadingCoeff)⁻¹) = 0 := by
      simp [Polynomial.aeval_mul, Polynomial.aeval_C, hroot]
    exact hroot'
  have hfinrank :
      Module.finrank K (RatFunc F) = (minpoly K (RatFunc.X : RatFunc F)).natDegree := by
    calc
      Module.finrank K (RatFunc F)
          = Module.finrank K (⊤ : IntermediateField K (RatFunc F)) := by
              symm
              exact (IntermediateField.finrank_top' (F := K) (E := RatFunc F))
      _ = Module.finrank K (IntermediateField.adjoin K ({RatFunc.X} : Set (RatFunc F))) := by
          rw [← htop]
      _ = (minpoly K (RatFunc.X : RatFunc F)).natDegree := by
          simpa using (IntermediateField.adjoin.finrank (K := K) (L := RatFunc F)
            (x := RatFunc.X) hInt)
  have hle :
      (minpoly K (RatFunc.X : RatFunc F)).natDegree ≤ max f.natDegree g.natDegree := by
    simpa [t, K] using
      minpoly_X_natDegree_le_max F f g hf hg hcoprime hfg
  -- TODO: lower bound for the minpoly degree.
  have hge :
      max f.natDegree g.natDegree ≤ (minpoly K (RatFunc.X : RatFunc F)).natDegree := by
    classical
    have hmax_ne : max f.natDegree g.natDegree ≠ 0 := by
      intro hmax0
      have hf0 : f.natDegree = 0 := by
        have : f.natDegree ≤ max f.natDegree g.natDegree := le_max_left _ _
        exact le_antisymm (this.trans (le_of_eq hmax0)) (Nat.zero_le _)
      have hg0 : g.natDegree = 0 := by
        have : g.natDegree ≤ max f.natDegree g.natDegree := le_max_right _ _
        exact le_antisymm (this.trans (le_of_eq hmax0)) (Nat.zero_le _)
      exact hfg ⟨hf0, hg0⟩
    have hp_ne : p ≠ 0 := by
      intro hp0
      have : max f.natDegree g.natDegree = 0 := by
        rw [← hdeg]
        simp [hp0]
      exact hmax_ne this

    -- `tK` is transcendental over `F`: otherwise `RatFunc.X` would be algebraic over `F`,
    -- contradicting `RatFunc.transcendental_X`.
    have htK_trans : Transcendental F (tK : K) := by
      refine (transcendental_iff).2 ?_
      intro P hP
      by_contra hP0
      have htK_alg : IsAlgebraic F (tK : K) := ⟨P, hP0, hP⟩
      have htK_int : IsIntegral F (tK : K) := IsAlgebraic.isIntegral htK_alg
      have ht_int : IsIntegral F (t : RatFunc F) := by
        have ht_int' : IsIntegral F (tK : RatFunc F) := by
          simpa using ((IntermediateField.isIntegral_iff (S := K) (x := tK)).1 htK_int)
        simpa [tK] using ht_int'
      have hK_alg : Algebra.IsAlgebraic F K := by
        simpa [K] using
          (IntermediateField.isAlgebraic_adjoin (K := F) (L := RatFunc F)
              (S := ({t} : Set (RatFunc F))) <|
            by
              intro x hx
              rcases (Set.mem_singleton_iff).1 hx with rfl
              exact ht_int)
      haveI : Algebra.IsAlgebraic F K := hK_alg
      have hX_alg : IsAlgebraic F (RatFunc.X : RatFunc F) := by
        exact
          IsIntegral.trans_isAlgebraic (R := F) (S := K) (A := RatFunc F)
            (a := (RatFunc.X : RatFunc F)) hInt
      have hX_not_alg : ¬ IsAlgebraic F (RatFunc.X : RatFunc F) := by
        intro hX_alg'
        have htrX : Transcendental F (RatFunc.X : RatFunc F) :=
          RatFunc.transcendental_X (K := F)
        have hinj : Function.Injective (Polynomial.aeval (RatFunc.X : RatFunc F)) :=
          (transcendental_iff_injective).1 htrX
        have hninj : ¬ Function.Injective (Polynomial.aeval (RatFunc.X : RatFunc F)) :=
          (isAlgebraic_iff_not_injective).1 hX_alg'
        exact hninj hinj
      exact (hX_not_alg hX_alg).elim

    -- Regard `K = F⟮t⟯` as the fraction field of `F[T]`, via evaluation at `tK`.
    letI : Algebra (Polynomial F) K :=
      RingHom.toAlgebra (Polynomial.aeval (tK : K)).toRingHom
    have hinj_aeval : Function.Injective (algebraMap (Polynomial F) K) := by
      have hinj' : Function.Injective (Polynomial.aeval (tK : K) : Polynomial F →ₐ[F] K) :=
        (transcendental_iff_injective).1 htK_trans
      simpa [RingHom.toAlgebra] using hinj'
    haveI : FaithfulSMul (Polynomial F) K :=
      (faithfulSMul_iff_algebraMap_injective (R := Polynomial F) (A := K)).2 hinj_aeval
    haveI : IsFractionRing (Polynomial F) K := by
      refine IsFractionRing.of_field (R := Polynomial F) (K := K) ?_
      intro z
      rcases
          (IntermediateField.mem_adjoin_simple_iff (F := F) (α := t) (x := (z : RatFunc F))).1 z.2 with
        ⟨r, s, hz⟩
      refine ⟨r, s, ?_⟩
      apply Subtype.ext
      -- Compare in the ambient field `RatFunc F` and use the explicit description of `F⟮t⟯`.
      have hr :
          ((algebraMap (Polynomial F) K r : K) : RatFunc F) =
            Polynomial.aeval (t : RatFunc F) r := by
        -- `algebraMap` is evaluation at `tK`, and coercion to `RatFunc F` agrees with evaluation at `t`.
        simpa [RingHom.toAlgebra, tK] using
          (Polynomial.aeval_algHom_apply
                (f := (K.val : K →ₐ[F] RatFunc F)) (x := tK) (p := r)).symm
      have hs :
          ((algebraMap (Polynomial F) K s : K) : RatFunc F) =
            Polynomial.aeval (t : RatFunc F) s := by
        simpa [RingHom.toAlgebra, tK] using
          (Polynomial.aeval_algHom_apply
                (f := (K.val : K →ₐ[F] RatFunc F)) (x := tK) (p := s)).symm
      refine hz.trans ?_
      -- Coercions out of an intermediate field are definitionally compatible with division.
      change (aeval t) r / (aeval t) s =
        ((algebraMap (Polynomial F) K r : K) : RatFunc F) /
          ((algebraMap (Polynomial F) K s : K) : RatFunc F)
      simp [hr, hs]

    -- The bivariate relation polynomial is irreducible, and remains irreducible after swapping.
    let q : (Polynomial F)[X] :=
      Polynomial.C f - (Y : (Polynomial F)[X]) * Polynomial.C g
    have hq_irred : Irreducible q :=
      relation_poly_irreducible_over_FXY F f g hg hcoprime
    let qswap : (Polynomial F)[X] := Polynomial.Bivariate.swap (R := F) q
    have hqswap_irred : Irreducible qswap := by
      simpa [qswap] using (hq_irred.map (Polynomial.Bivariate.swap (R := F)))

    -- After mapping coefficients `F[T] → K` by `T ↦ tK`, the swapped relation polynomial is `p`.
    have hqswap_map :
        qswap.map (algebraMap (Polynomial F) K) = p := by
      -- `swap` sends `Y ↦ C X` and turns coefficients in `F[X]` into polynomials in `Y`.
      have hswap_C (u : F[X]) :
          Polynomial.Bivariate.swap (R := F) (Polynomial.C u : (Polynomial F)[X]) =
            u.map Polynomial.C := by
        classical
        induction u using Polynomial.induction_on' with
        | add u v hu hv =>
            simp [hu, hv, map_add]
        | monomial n a =>
            simp [Polynomial.C_mul_X_pow_eq_monomial]
      have hqswap' :
          qswap =
            f.map Polynomial.C - (Polynomial.C (X : Polynomial F)) * (g.map Polynomial.C) := by
        -- Avoid unfolding `swap` into `aevalAeval` (it can cause simp loops).
        simp only [qswap, q, map_sub, map_mul, Polynomial.Bivariate.swap_Y, hswap_C]
      -- Map coefficients `F[X] → K` by `X ↦ tK`.
      -- This sends `f.map C` to `map (algebraMap F K) f` and `C X` to `C tK`.
      have hcomp :
          (algebraMap (Polynomial F) K).comp Polynomial.C = algebraMap F K := by
        refine RingHom.ext fun a => ?_
        -- `algebraMap F[X] K` is evaluation at `tK`.
        change (Polynomial.aeval (tK : K)) (Polynomial.C a : Polynomial F) = algebraMap F K a
        simp
      have hX :
          (algebraMap (Polynomial F) K) (X : Polynomial F) = tK := by
        change (Polynomial.aeval (tK : K)) (X : Polynomial F) = tK
        simp
      simp [hqswap', p, Polynomial.map_sub, Polynomial.map_mul, Polynomial.map_C, Polynomial.map_map, hcomp, hX]

    -- Use Gauss' lemma to transport irreducibility to `K[X]`.
    have hqswap_natDegree : qswap.natDegree = p.natDegree := by
      have hnd :
          (qswap.map (algebraMap (Polynomial F) K)).natDegree = qswap.natDegree :=
        Polynomial.natDegree_map_eq_of_injective hinj_aeval qswap
      have : p.natDegree = qswap.natDegree := by
        simpa [hqswap_map] using hnd
      exact this.symm
    have hqswap_natDegree_ne : qswap.natDegree ≠ 0 := by
      have hp_natDegree_ne : p.natDegree ≠ 0 := by
        simpa [hdeg] using hmax_ne
      exact fun h0 => hp_natDegree_ne <| by simpa [hqswap_natDegree] using h0
    have hqswap_prim : qswap.IsPrimitive :=
      hqswap_irred.isPrimitive hqswap_natDegree_ne
    have hp_irred' : Irreducible (qswap.map (algebraMap (Polynomial F) K)) := by
      exact
        (Polynomial.IsPrimitive.irreducible_iff_irreducible_map_fraction_map (R := Polynomial F) (K := K)
              hqswap_prim).1
          hqswap_irred
    have hp_irred : Irreducible p := by
      simpa [hqswap_map] using hp_irred'

    -- Identify the minpoly with the monic associate of `p`, and read off the degree.
    have hminpoly :
        p * Polynomial.C p.leadingCoeff⁻¹ = minpoly K (RatFunc.X : RatFunc F) :=
      minpoly.eq_of_irreducible (A := K) (x := (RatFunc.X : RatFunc F)) hp_irred hroot
    have hdeg_minpoly :
        (minpoly K (RatFunc.X : RatFunc F)).natDegree = p.natDegree := by
      calc
        (minpoly K (RatFunc.X : RatFunc F)).natDegree =
            (p * Polynomial.C p.leadingCoeff⁻¹).natDegree := by
              simp [hminpoly]
        _ = p.natDegree := by
            simpa using
              (Polynomial.natDegree_mul_leadingCoeff_inv (p := p) (q := p) hp_ne)
    exact le_of_eq <| by simp [hdeg, hdeg_minpoly]
  have hdeg_minpoly :
      (minpoly K (RatFunc.X : RatFunc F)).natDegree = max f.natDegree g.natDegree :=
    le_antisymm hle hge
  exact hfinrank.trans hdeg_minpoly
