import Mathlib
import Question_bench.FATEH.«45»

open IntermediateField
open scoped Polynomial

/-! Helper lemmas for the Galois criterion over a rational function field. -/

/-- The rational function field is generated by `X` over the base field. -/
lemma ratfunc_adjoin_X_eq_top' (K : Type*) [Field K] :
    IntermediateField.adjoin K ({RatFunc.X} : Set (RatFunc K)) = ⊤ := by
  refine top_unique ?_
  intro x _
  refine RatFunc.induction_on x ?_
  intro p q hq
  refine (IntermediateField.mem_adjoin_simple_iff (F := K) (E := RatFunc K)
    (α := (RatFunc.X : RatFunc K)) _).2 ?_
  refine ⟨p, q, ?_⟩
  simp [RatFunc.aeval_X_left_eq_algebraMap]

/-- Adjoining `X` to `K⟮X^n⟯` still yields the full rational function field. -/
lemma ratfunc_adjoin_X_pow_eq_top (K : Type*) [Field K] (n : ℕ) :
    IntermediateField.adjoin K⟮(RatFunc.X ^ n : RatFunc K)⟯
      ({RatFunc.X} : Set (RatFunc K)) = ⊤ := by
  have htop : IntermediateField.adjoin K ({RatFunc.X} : Set (RatFunc K)) = ⊤ :=
    ratfunc_adjoin_X_eq_top' (K := K)
  exact (IntermediateField.adjoin_eq_top_of_adjoin_eq_top (F := K)
    (E := K⟮(RatFunc.X ^ n : RatFunc K)⟯) (K := RatFunc K)
    (S := ({RatFunc.X} : Set (RatFunc K))) htop)

/-- Any nontrivial root of unity in `RatFunc K` is constant. -/
lemma rootsOfUnity_ratfunc_eq_consts (K : Type*) [Field K] {n : ℕ} (hn : 0 < n)
    {ζ : RatFunc K} (hζ : ζ ^ n = 1) : ∃ c : K, RatFunc.C c = ζ := by
  classical
  have hpow :
      (algebraMap (Polynomial K) (RatFunc K) (RatFunc.num ζ)
        / algebraMap (Polynomial K) (RatFunc K) (RatFunc.denom ζ)) ^ n = 1 := by
    have hpow' := hζ
    rw [← RatFunc.num_div_denom ζ] at hpow'
    simpa using hpow'
  have hpow'' :
      (algebraMap (Polynomial K) (RatFunc K) (RatFunc.num ζ)) ^ n /
        (algebraMap (Polynomial K) (RatFunc K) (RatFunc.denom ζ)) ^ n = 1 := by
    have hpow'' := hpow
    rw [div_pow] at hpow''
    exact hpow''
  have hpow' :
      (algebraMap (Polynomial K) (RatFunc K) (RatFunc.num ζ)) ^ n =
        (algebraMap (Polynomial K) (RatFunc K) (RatFunc.denom ζ)) ^ n := by
    have hden : (algebraMap (Polynomial K) (RatFunc K) (RatFunc.denom ζ)) ^ n ≠ 0 := by
      exact pow_ne_zero _ (RatFunc.algebraMap_ne_zero (RatFunc.denom_ne_zero ζ))
    simpa [one_mul] using (div_eq_iff hden).1 hpow''
  have hpow_poly : (RatFunc.num ζ) ^ n = (RatFunc.denom ζ) ^ n := by
    apply (RatFunc.algebraMap_injective K)
    simpa [map_pow] using hpow'
  have hdiv : RatFunc.num ζ ∣ (RatFunc.denom ζ) ^ n := by
    have hdiv' : RatFunc.num ζ ∣ (RatFunc.num ζ) ^ n :=
      dvd_pow_self _ (Nat.ne_zero_of_lt hn)
    simpa [hpow_poly] using hdiv'
  have hdiv' : RatFunc.denom ζ ∣ (RatFunc.num ζ) ^ n := by
    have hdiv'' : RatFunc.denom ζ ∣ (RatFunc.denom ζ) ^ n :=
      dvd_pow_self _ (Nat.ne_zero_of_lt hn)
    simpa [hpow_poly] using hdiv''
  have hcop := RatFunc.isCoprime_num_denom (K := K) ζ
  have hunit_num : IsUnit (RatFunc.num ζ) :=
    (IsCoprime.pow_right hcop).isUnit_of_dvd hdiv
  have hunit_denom : IsUnit (RatFunc.denom ζ) :=
    (IsCoprime.pow_right hcop.symm).isUnit_of_dvd hdiv'
  rcases (Polynomial.isUnit_iff.mp hunit_num) with ⟨c, hc, hnum⟩
  rcases (Polynomial.isUnit_iff.mp hunit_denom) with ⟨d, hd, hden⟩
  refine ⟨c / d, ?_⟩
  have hnum' : RatFunc.num ζ = Polynomial.C c := by simp [hnum]
  have hden' : RatFunc.denom ζ = Polynomial.C d := by simp [hden]
  have hfrac :
      algebraMap (Polynomial K) (RatFunc K) (RatFunc.num ζ)
        / algebraMap (Polynomial K) (RatFunc K) (RatFunc.denom ζ) = ζ := by
    simp [RatFunc.num_div_denom]
  calc
    RatFunc.C (c / d) = RatFunc.C c / RatFunc.C d := by simp
    _ =
        algebraMap (Polynomial K) (RatFunc K) (RatFunc.num ζ)
          / algebraMap (Polynomial K) (RatFunc K) (RatFunc.denom ζ) := by
        simp [hnum', hden']
    _ = ζ := hfrac

/-! ### Galois criterion for `K(t)/K(t^n)` -/

/-- Primitive `n`-th roots in a finite field are equivalent to `q ≡ 1 (mod n)`. -/
lemma primitiveRoots_nonempty_iff_modEq_one_galoisField (p m n : ℕ) (hn : 0 < n) (hm : 1 ≤ m)
    [Fact p.Prime] :
    (primitiveRoots n (GaloisField p m)).Nonempty ↔ p ^ m ≡ 1 [MOD n] := by
  classical
  let K := GaloisField p m
  haveI : Fintype K := Fintype.ofFinite K
  have hm0 : m ≠ 0 := Nat.ne_zero_of_lt (Nat.succ_le_iff.mp hm)
  have hcardK : Fintype.card K = p ^ m := by
    simpa [Nat.card_eq_fintype_card] using (GaloisField.card (p := p) (n := m) hm0)
  have hcard_units : Fintype.card Kˣ = p ^ m - 1 := by
    simpa [hcardK] using (Fintype.card_units (α := K))
  constructor
  · intro h
    rcases h with ⟨ζ, hζ⟩
    have hprim : IsPrimitiveRoot ζ n := (mem_primitiveRoots hn).1 hζ
    have hunit : IsPrimitiveRoot (hprim.isUnit (Nat.ne_zero_of_lt hn)).unit n :=
      IsPrimitiveRoot.isUnit_unit (Nat.ne_zero_of_lt hn) hprim
    have horder : orderOf (hprim.isUnit (Nat.ne_zero_of_lt hn)).unit = n :=
      (IsPrimitiveRoot.iff_orderOf).1 hunit
    have hdiv : n ∣ Fintype.card Kˣ := by
      simpa [horder] using
        (orderOf_dvd_card (x := (hprim.isUnit (Nat.ne_zero_of_lt hn)).unit))
    have hdiv' : n ∣ p ^ m - 1 := by simpa [hcard_units] using hdiv
    have h1 : (1 : ℕ) ≤ p ^ m := by
      exact Nat.succ_le_of_lt (pow_pos (Nat.pos_of_ne_zero (Fact.out : p.Prime).ne_zero) _)
    exact (Nat.modEq_iff_dvd' (a := 1) (b := p ^ m) (n := n) h1).2 hdiv' |>.symm
  · intro h
    have h1 : (1 : ℕ) ≤ p ^ m := by
      exact Nat.succ_le_of_lt (pow_pos (Nat.pos_of_ne_zero (Fact.out : p.Prime).ne_zero) _)
    have hdiv : n ∣ p ^ m - 1 :=
      (Nat.modEq_iff_dvd' (a := 1) (b := p ^ m) (n := n) h1).1 h.symm
    have hdiv' : n ∣ Fintype.card Kˣ := by simpa [hcard_units] using hdiv
    obtain ⟨g, hg⟩ := IsCyclic.exists_ofOrder_eq_natCard (α := Kˣ)
    have hg' : orderOf g = Fintype.card Kˣ := by
      simpa [Nat.card_eq_fintype_card] using hg
    have horder : orderOf (g ^ (orderOf g / n)) = n := by
      have hg0 : orderOf g ≠ 0 := by
        have hcard : (Fintype.card Kˣ) ≠ 0 :=
          ne_of_gt (Fintype.card_pos_iff.mpr ⟨1⟩)
        rw [hg']
        exact hcard
      have hdivg : n ∣ orderOf g := by simpa [hg'] using hdiv'
      exact orderOf_pow_orderOf_div (x := g) hg0 hdivg
    have hprim_unit : IsPrimitiveRoot (g ^ (orderOf g / n)) n :=
      (IsPrimitiveRoot.iff_orderOf).2 horder
    have hprim : IsPrimitiveRoot ((g ^ (orderOf g / n)) : K) n := by
      simpa using (IsPrimitiveRoot.coe_units_iff.mpr hprim_unit)
    exact ⟨(g ^ (orderOf g / n) : K), (mem_primitiveRoots hn).2 hprim⟩

set_option maxHeartbeats 400000 in
-- Needed for definitional equality checks in the Galois criterion proof.
/-- Galois criterion for the rational function extension `K(t)/K(t^n)` via primitive roots. -/
lemma ratfunc_isGalois_X_pow_iff_primitiveRoots (K : Type) [Field K] (n : ℕ) (hn : 1 ≤ n) :
    IsGalois K⟮(RatFunc.X ^ n : RatFunc K)⟯ (RatFunc K) ↔ (primitiveRoots n K).Nonempty := by
  classical
  let L := RatFunc K
  let F : IntermediateField K L := K⟮(RatFunc.X ^ n : L)⟯
  change IsGalois F L ↔ (primitiveRoots n K).Nonempty
  have hnpos : 0 < n := Nat.succ_le_iff.mp hn
  constructor
  · intro hG
    -- Compute the minpoly degree using the finite-degree lemma from `FATEH/45`.
    have hfinrank :
        Module.finrank F L = n := by
      have hf : (Polynomial.X ^ n : K[X]) ≠ 0 := by
        exact pow_ne_zero _ Polynomial.X_ne_zero
      have hg : (1 : K[X]) ≠ 0 := one_ne_zero
      have hcoprime : IsCoprime (Polynomial.X ^ n : K[X]) (1 : K[X]) := by
        simpa using (isCoprime_one_right (x := (Polynomial.X ^ n : K[X])))
      have hfg : ¬((Polynomial.X ^ n : K[X]).natDegree = 0 ∧ (1 : K[X]).natDegree = 0) := by
        intro h
        have hdeg : (Polynomial.X ^ n : K[X]).natDegree = n := by
          exact (Polynomial.natDegree_X_pow (R := K) (n := n))
        have : n = 0 := hdeg.symm.trans h.1
        exact (Nat.ne_zero_of_lt hnpos) this
      have hfinrank' :=
        finrank_adjoin_dvd_eq_max_natDegree (F := K) (f := Polynomial.X ^ n) (g := 1)
          hf hg hcoprime hfg
      have hXpow : ((Polynomial.X ^ n : K[X]) : RatFunc K) = (RatFunc.X ^ n : RatFunc K) := by
        have h := RatFunc.aeval_X_left_eq_algebraMap (K := K) (p := Polynomial.X ^ n)
        rw [Polynomial.aeval_X_pow] at h
        exact h.symm
      have hdivX :
          ((Polynomial.X ^ n : K[X]) : RatFunc K) / (1 : K[X]) = (RatFunc.X ^ n : RatFunc K) := by
        have h1 : ((1 : K[X]) : RatFunc K) = (1 : RatFunc K) := by
          exact map_one (algebraMap K[X] (RatFunc K))
        rw [hXpow, h1]
        simp
      have hfinrank'' :
          Module.finrank K⟮((Polynomial.X ^ n : K[X]) : RatFunc K) / (1 : K[X])⟯
            (RatFunc K) = n := by
        have hfinrank'' := hfinrank'
        rw [Polynomial.natDegree_X_pow, Polynomial.natDegree_one,
          max_eq_left (Nat.zero_le _)] at hfinrank''
        exact hfinrank''
      have hAdjoin :
          K⟮(RatFunc.X ^ n : RatFunc K)⟯ =
            K⟮((Polynomial.X ^ n : K[X]) : RatFunc K) / (1 : K[X])⟯ := by
        apply le_antisymm
        · refine (IntermediateField.adjoin_simple_le_iff (F := K) (E := RatFunc K)
            (K := K⟮((Polynomial.X ^ n : K[X]) : RatFunc K) / (1 : K[X])⟯)
            (α := (RatFunc.X ^ n : RatFunc K))).2 ?_
          have hx :
              ((Polynomial.X ^ n : K[X]) : RatFunc K) / (1 : K[X]) ∈
                K⟮((Polynomial.X ^ n : K[X]) : RatFunc K) / (1 : K[X])⟯ :=
            IntermediateField.mem_adjoin_simple_self (F := K)
              (α := ((Polynomial.X ^ n : K[X]) : RatFunc K) / (1 : K[X]))
          simpa [hdivX] using hx
        · refine (IntermediateField.adjoin_simple_le_iff (F := K) (E := RatFunc K)
            (K := K⟮(RatFunc.X ^ n : RatFunc K)⟯)
            (α := ((Polynomial.X ^ n : K[X]) : RatFunc K) / (1 : K[X]))).2 ?_
          have hx : (RatFunc.X ^ n : RatFunc K) ∈ K⟮(RatFunc.X ^ n : RatFunc K)⟯ :=
            IntermediateField.mem_adjoin_simple_self (F := K)
              (α := (RatFunc.X ^ n : RatFunc K))
          simpa [hdivX.symm] using hx
      have hcongr :
          Module.finrank K⟮(RatFunc.X ^ n : RatFunc K)⟯ (RatFunc K) =
            Module.finrank K⟮((Polynomial.X ^ n : K[X]) : RatFunc K) / (1 : K[X])⟯ (RatFunc K) :=
        congrArg (fun F : IntermediateField K (RatFunc K) =>
          Module.finrank F (RatFunc K)) hAdjoin
      change Module.finrank K⟮(RatFunc.X ^ n : RatFunc K)⟯ (RatFunc K) = n
      calc
        Module.finrank K⟮(RatFunc.X ^ n : RatFunc K)⟯ (RatFunc K) =
            Module.finrank K⟮((Polynomial.X ^ n : K[X]) : RatFunc K) / (1 : K[X])⟯ (RatFunc K) :=
          hcongr
        _ = n := hfinrank''
    -- The minpoly has degree `n` because `RatFunc.X` generates `L` over `F`.
    let t : F :=
      ⟨RatFunc.X ^ n,
        (IntermediateField.subset_adjoin (F := K) ({RatFunc.X ^ n} : Set L)) (by simp)⟩
    have ht : (algebraMap F L t) = (RatFunc.X ^ n : L) := by
      simp [t]
    have hInt : IsIntegral F (RatFunc.X : L) := by
      refine ⟨Polynomial.X ^ n - Polynomial.C t, ?_, ?_⟩
      · simpa using (Polynomial.monic_X_pow_sub_C (a := t) (n := n)
          (Nat.ne_zero_of_lt hnpos))
      · simp; rw [ht]; simp
    have htop : IntermediateField.adjoin F ({RatFunc.X} : Set L) = ⊤ := by
      simpa [F] using ratfunc_adjoin_X_pow_eq_top (K := K) n
    have hdeg :
        (minpoly F (RatFunc.X : L)).natDegree = n := by
      have hfinrank' :
          Module.finrank F L = (minpoly F (RatFunc.X : L)).natDegree := by
        calc
          Module.finrank F L = Module.finrank F (⊤ : IntermediateField F L) := by
            exact (IntermediateField.finrank_top' (F := F) (E := L)).symm
          _ = Module.finrank F (IntermediateField.adjoin F ({RatFunc.X} : Set L)) := by
            rw [htop]
          _ = (minpoly F (RatFunc.X : L)).natDegree := by
            simpa using
              (IntermediateField.adjoin.finrank (K := F) (L := L) (x := RatFunc.X) hInt)
      exact hfinrank'.symm.trans hfinrank
    -- Roots of the minpoly give `n` distinct `n`-th roots of unity.
    let P : F[X] := minpoly F (RatFunc.X : L)
    have hdiv : P ∣ Polynomial.X ^ n - Polynomial.C t := by
      apply minpoly.dvd
      simp
      rw [ht]
      simp
    have hPne : P ≠ 0 :=
      minpoly.ne_zero (IsGalois.integral (F := F) (E := L) (x := (RatFunc.X : L)))
    have hsepP : P.Separable := by
      simpa [P, IsSeparable] using (IsGalois.separable (F := F) (E := L) (x := (RatFunc.X : L)))
    have hsplitP : (P.map (algebraMap F L)).Splits :=
      IsGalois.splits (F := F) (E := L) (x := (RatFunc.X : L))
    have hcard_root : Fintype.card (P.rootSet L) = n := by
      simpa [P, hdeg] using (Polynomial.card_rootSet_eq_natDegree (K := L) hsepP hsplitP)
    have hroot_eq :
        ∀ {x : L}, x ∈ P.rootSet L → x ^ n = (RatFunc.X : L) ^ n := by
      intro x hx
      have hx0 : Polynomial.aeval x P = 0 :=
        Polynomial.aeval_eq_zero_of_mem_rootSet (p := P) (a := x) hx
      have hx0' :
          Polynomial.aeval x
              (Polynomial.X ^ n -
                Polynomial.C
                  (⟨RatFunc.X ^ n,
                    (IntermediateField.subset_adjoin (F := K)
                      ({RatFunc.X ^ n} : Set L)) (by simp)⟩ : F)) =
            0 := by
        exact Polynomial.aeval_eq_zero_of_dvd_aeval_eq_zero hdiv hx0
      have : x ^ n - (RatFunc.X : L) ^ n = 0 := by
        simpa using hx0'
      exact sub_eq_zero.mp this
    haveI : NeZero n := ⟨Nat.ne_zero_of_lt hnpos⟩
    have hcard_le : n ≤ Fintype.card (rootsOfUnity n L) := by
      classical
      let f : {x : L // x ∈ P.rootSet L} → rootsOfUnity n L := fun x =>
        by
          have hxne : (x.1 : L) ≠ 0 := by
            have hXne : (RatFunc.X : L) ^ n ≠ 0 := pow_ne_zero _ RatFunc.X_ne_zero
            intro hx0
            exact hXne (by simpa [hx0, hnpos.ne'] using (hroot_eq x.property).symm)
          have hpow : (x.1 / RatFunc.X) ^ n = (1 : L) := by
            have hXne : (RatFunc.X : L) ^ n ≠ 0 := pow_ne_zero _ RatFunc.X_ne_zero
            calc
              (x.1 / RatFunc.X) ^ n = x.1 ^ n / (RatFunc.X : L) ^ n := by
                simp [div_pow]
              _ = 1 := by
                exact (div_eq_iff hXne).2 (by simp [hroot_eq x.property])
          refine ⟨Units.mk0 (x.1 / RatFunc.X) (div_ne_zero hxne RatFunc.X_ne_zero), ?_⟩
          ext
          simp [hpow]
      have hf_inj : Function.Injective f := by
        intro x y hxy
        have hxy' : (x.1 / RatFunc.X : L) = y.1 / RatFunc.X := by
          have h1 := congrArg (fun u : rootsOfUnity n L => (u : Lˣ)) hxy
          have h2 := congrArg (fun u : Lˣ => (u : L)) h1
          simpa [f] using h2
        apply Subtype.ext
        exact (div_left_inj' (c := (RatFunc.X : L)) RatFunc.X_ne_zero).1 hxy'
      have hle' :
          Fintype.card {x : L // x ∈ P.rootSet L} ≤ Fintype.card (rootsOfUnity n L) :=
        Fintype.card_le_of_injective f hf_inj
      simpa [hcard_root] using hle'
    have hcard_unity : Fintype.card (rootsOfUnity n L) = n :=
      le_antisymm (card_rootsOfUnity (R := L) (k := n)) hcard_le
    obtain ⟨ζ, hζ⟩ := (card_rootsOfUnity_eq_iff_exists_isPrimitiveRoot (R := L) (n := n)).1
      hcard_unity
    have hζpow : (ζ : L) ^ n = 1 := hζ.pow_eq_one
    rcases (rootsOfUnity_ratfunc_eq_consts (K := K) (n := n) hnpos hζpow) with ⟨c, hc⟩
    have hζ' : IsPrimitiveRoot (RatFunc.C c : L) n := by simpa [hc] using hζ
    have hc' : IsPrimitiveRoot c n :=
      IsPrimitiveRoot.of_map_of_injective (f := RatFunc.C) (h := hζ') RatFunc.C_injective
    exact ⟨c, (mem_primitiveRoots hnpos).2 hc'⟩
  · intro hprim
    rcases hprim with ⟨ζ, hζ⟩
    have hζ' : IsPrimitiveRoot ζ n := (mem_primitiveRoots hnpos).1 hζ
    have hζL : IsPrimitiveRoot (algebraMap K L ζ) n :=
      hζ'.map_of_injective (algebraMap K L).injective
    let t : F :=
      ⟨RatFunc.X ^ n,
        (IntermediateField.subset_adjoin (F := K) ({RatFunc.X ^ n} : Set L)) (by simp)⟩
    have ht : (algebraMap F L t) = (RatFunc.X ^ n : L) := by
      simp [t]
    let P : F[X] := Polynomial.X ^ n - Polynomial.C t
    have hsplit : (P.map (algebraMap F L)).Splits := by
      have hsplit' :
          (Polynomial.X ^ n - Polynomial.C (RatFunc.X ^ n : L)).Splits :=
        (X_pow_sub_C_splits_of_isPrimitiveRoot hζL (by rfl))
      simpa [P, t] using hsplit'
    have hroot : IntermediateField.adjoin F (P.rootSet L) = ⊤ := by
      have hPne : P ≠ 0 := by
        simpa [P] using (Polynomial.X_pow_sub_C_ne_zero hnpos (t : F))
      have hXroot : (RatFunc.X : L) ∈ P.rootSet L := by
        refine (Polynomial.mem_rootSet'.2 ?_)
        constructor
        · simpa [P, t] using
            (Polynomial.X_pow_sub_C_ne_zero (R := L) hnpos (RatFunc.X ^ n : L))
        · simp [P, t]; rw [ht]; simp
      have hsubset : ({RatFunc.X} : Set L) ⊆ P.rootSet L := by
        intro x hx
        have hx' : x = RatFunc.X := by simpa [Set.mem_singleton_iff] using hx
        simpa [hx'] using hXroot
      have htop : IntermediateField.adjoin F ({RatFunc.X} : Set L) = ⊤ := by
        dsimp [F, L]
        simpa using ratfunc_adjoin_X_pow_eq_top (K := K) n
      apply top_unique
      have hle :
          IntermediateField.adjoin F ({RatFunc.X} : Set L) ≤
            IntermediateField.adjoin F (P.rootSet L) := by
        refine (IntermediateField.adjoin_le_iff (F := F) (E := L)).2 ?_
        intro x hx
        have hx' : x ∈ P.rootSet L := hsubset hx
        exact IntermediateField.subset_adjoin (F := F) (S := P.rootSet L) hx'
      have hle' := hle
      rw [htop] at hle'
      exact hle'
    have hsep : P.Separable := by
      haveI : NeZero n := ⟨Nat.ne_zero_of_lt hnpos⟩
      have hnK : (n : K) ≠ 0 := by
        have hne : (0 : K) ≠ (n : K) := (IsPrimitiveRoot.neZero' (R := K) hζ').ne'
        exact ne_comm.mp hne
      have hneL : (n : L) ≠ 0 := by
        have hne : (0 : L) ≠ (n : L) := (IsPrimitiveRoot.neZero' (R := L) hζL).ne'
        exact ne_comm.mp hne
      have hnF : (n : F) ≠ 0 := by
        intro h0
        apply hneL
        exact congrArg Subtype.val h0
      have htne : (t : F) ≠ 0 := by
        intro h0
        have h0' : (RatFunc.X ^ n : L) = 0 :=
          congrArg Subtype.val h0
        have hXne : (RatFunc.X : L) ^ n ≠ 0 := pow_ne_zero _ RatFunc.X_ne_zero
        exact hXne h0'
      simpa [P] using (Polynomial.separable_X_pow_sub_C (a := t) hnF htne)
    haveI : P.IsSplittingField F L :=
      (isSplittingField_iff_intermediateField (K := F) (L := L) (p := P)).2
        ⟨hsplit, hroot⟩
    exact IsGalois.of_separable_splitting_field (p := P) hsep

/-- Let $q$ denote a power of a prime $p$. Show that the extension $\mathbb{F}_q(t^{1/n})$ over
$\mathbb{F}_q(t)$ is Galois if and only if $q \equiv 1 \bmod n$. -/
theorem isGalois_galoisField_X_pow_iff_modEq_one (p m n : ℕ) (hn : 1 ≤ n) (hm : 1 ≤ m)
    [Fact p.Prime] :  IsGalois (GaloisField p m)⟮(RatFunc.X ^ n : RatFunc (GaloisField p m))⟯
    (RatFunc (GaloisField p m)) ↔ p ^ m ≡ 1 [MOD n] := by
  classical
  have hnpos : 0 < n := Nat.succ_le_iff.mp hn
  simpa using
    (ratfunc_isGalois_X_pow_iff_primitiveRoots (K := GaloisField p m) n hn).trans
      (primitiveRoots_nonempty_iff_modEq_one_galoisField (p := p) (m := m) (n := n) hnpos hm)
