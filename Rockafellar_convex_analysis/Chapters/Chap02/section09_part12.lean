import Mathlib
import Rockafellar_convex_analysis.Chapters.Chap02.section09_part11

noncomputable section
open scoped Pointwise
open scoped BigOperators
open scoped Topology
open scoped RealInnerProductSpace
open Filter

section Chap02
section Section09
set_option maxHeartbeats 800000 in
/-- Theorem 9.7. Let `f` be a closed proper convex function on `ℝ^n` with `f(0) > 0`,
and let `k` be the positively homogeneous convex function generated by `f`. Then `k` is
proper and `(convexFunctionClosure k)(x)` is the infimum of `(f λ)(x)` over `λ > 0`
together with `λ = 0^+` (encoded here as `f0_plus`), the infimum being attained for each
`x`. If `0 ∈ dom f`, then `k` is closed and the `λ = 0^+` term can be omitted
(but the infimum might not be attained). -/
theorem closure_posHomogeneousGenerated_infimum_rightScalarMultiple {n : Nat}
    {f f0_plus : (Fin n → Real) → EReal}
    (hfclosed : ClosedConvexFunction f)
    (hfproper : ProperConvexFunctionOn (Set.univ : Set (Fin n → Real)) f)
    (hf0 : f (0 : Fin n → Real) > (0 : EReal))
    (hrec :
      Set.recessionCone (epigraph (Set.univ : Set (Fin n → Real)) f) =
        epigraph (Set.univ : Set (Fin n → Real)) f0_plus) :
    let k := positivelyHomogeneousConvexFunctionGenerated f
    (ProperConvexFunctionOn (Set.univ : Set (Fin n → Real)) k) ∧
      (∀ x : Fin n → Real,
        convexFunctionClosure k x =
          sInf
            (Set.insert (f0_plus x)
              { z : EReal | ∃ lam : Real, 0 < lam ∧ z = rightScalarMultiple f lam x })) ∧
      (∀ x : Fin n → Real,
        ∃ z ∈
            Set.insert (f0_plus x)
              { z : EReal | ∃ lam : Real, 0 < lam ∧ z = rightScalarMultiple f lam x },
          convexFunctionClosure k x = z) ∧
      ((0 : Fin n → Real) ∈ effectiveDomain (Set.univ : Set (Fin n → Real)) f →
        ClosedConvexFunction k ∧
          (∀ x : Fin n → Real,
            k x =
              sInf { z : EReal | ∃ lam : Real, 0 < lam ∧ z = rightScalarMultiple f lam x })) := by
  classical
  -- Unfold the `let`-binding to work with `k`.
  dsimp
  set k := positivelyHomogeneousConvexFunctionGenerated f with hk
  have hfconv : ConvexFunctionOn (Set.univ : Set (Fin n → Real)) f := hfproper.1
  have hfinite : ∃ x, f x ≠ (⊤ : EReal) := by
    rcases hfproper.2.1 with ⟨⟨x, μ⟩, hx⟩
    have hle : f x ≤ (μ : EReal) := (mem_epigraph_univ_iff (f := f)).1 hx
    refine ⟨x, ?_⟩
    intro htop
    have hle' : False := by
      refine (not_top_le_coe (r := μ) ?_)
      rw [← htop]
      exact hle
    exact hle'
  have hk_formula :
      ∀ x : Fin n → Real,
        k x = sInf { z : EReal | ∃ lam : Real, 0 ≤ lam ∧ z = rightScalarMultiple f lam x } := by
    rw [hk]
    exact (infimumRepresentation_posHomogeneousHull (h := f) hfconv hfinite).1
  set C : Set (Fin (n + 1) → Real) :=
    (prodLinearEquiv_append_coord (n := n)) '' epigraph (Set.univ : Set (Fin n → Real)) f
  have hCne : Set.Nonempty C := by
    rcases hfproper.2.1 with ⟨p, hp⟩
    exact ⟨(prodLinearEquiv_append_coord (n := n)) p, ⟨p, hp, rfl⟩⟩
  have hCclosed : IsClosed C := by
    have hclosed_sub :
        ∀ α : Real, IsClosed {x : Fin n → Real | f x ≤ (α : EReal)} :=
      (lowerSemicontinuous_iff_closed_sublevel_iff_closed_epigraph (f := f)).1.mp hfclosed.2
    have hclosed_epi :
        IsClosed (epigraph (Set.univ : Set (Fin n → Real)) f) :=
      (lowerSemicontinuous_iff_closed_sublevel_iff_closed_epigraph (f := f)).2.mp hclosed_sub
    let hhome := (prodLinearEquiv_append_coord (n := n)).toAffineEquiv.toHomeomorphOfFiniteDimensional
    have hclosed' :
        IsClosed ((hhome : _ → _) '' epigraph (Set.univ : Set (Fin n → Real)) f) :=
      (hhome.isClosed_image (s := epigraph (Set.univ : Set (Fin n → Real)) f)).2 hclosed_epi
    simpa [C, hhome, AffineEquiv.coe_toHomeomorphOfFiniteDimensional] using hclosed'
  have hCconv : Convex Real C := by
    have hconv_epi :
        Convex Real (epigraph (Set.univ : Set (Fin n → Real)) f) := by
      simpa [ConvexFunction] using
        (convex_epigraph_of_convexFunctionOn (f := f) (hf := hfconv))
    simpa [C] using hconv_epi.linear_image (prodLinearEquiv_append_coord (n := n)).toLinearMap
  have hC0 : (0 : Fin (n + 1) → Real) ∉ C := by
    intro h0
    rcases h0 with ⟨p, hp, hp0⟩
    have hp0' : p = 0 := by
      apply (prodLinearEquiv_append_coord (n := n)).injective
      simpa using hp0
    subst hp0'
    have hle : f (0 : Fin n → Real) ≤ (0 : EReal) := by
      simpa using (mem_epigraph_univ_iff (f := f)).1 hp
    exact (not_lt_of_ge hle) hf0
  have hclosure_union :
      closure (convexConeGenerated (n + 1) C) =
        (⋃ (lam : Real) (_ : 0 < lam),
          (prodLinearEquiv_append_coord (n := n)) ''
            epigraph (Set.univ : Set (Fin n → Real)) (rightScalarMultiple f lam)) ∪
        (prodLinearEquiv_append_coord (n := n)) '' epigraph (Set.univ : Set (Fin n → Real)) f0_plus := by
    simpa [C] using
      (closure_convexConeGenerated_embedded_epigraph_eq_union
        (n := n) (f := f) (f0_plus := f0_plus) hfconv hrec hCne hCclosed hCconv hC0)
  have hcone_img :
      (prodLinearEquiv_append_coord (n := n)) '' convexConeGeneratedEpigraph f =
        convexConeGenerated (n + 1) C := by
    simpa [C] using
      (convexConeGenerated_embedded_epigraph_eq_image_convexConeGeneratedEpigraph
        (n := n) (f := f) hfconv)
  have hclosure_union' :
      closure ((prodLinearEquiv_append_coord (n := n)) '' convexConeGeneratedEpigraph f) =
        (⋃ (lam : Real) (_ : 0 < lam),
          (prodLinearEquiv_append_coord (n := n)) ''
            epigraph (Set.univ : Set (Fin n → Real)) (rightScalarMultiple f lam)) ∪
        (prodLinearEquiv_append_coord (n := n)) '' epigraph (Set.univ : Set (Fin n → Real)) f0_plus := by
    calc
      closure ((prodLinearEquiv_append_coord (n := n)) '' convexConeGeneratedEpigraph f) =
          closure (convexConeGenerated (n + 1) C) := by
        simp [hcone_img]
      _ = _ := hclosure_union
  -- The generated cone sits inside the epigraph of `k`.
  have hcone_subset :
      convexConeGeneratedEpigraph f ⊆
        epigraph (Set.univ : Set (Fin n → Real)) k := by
    rw [hk]
    exact (convexConeGeneratedEpigraph_subset_epigraph_posHom (f := f))
  have hclosure_cone_subset :
      closure ((prodLinearEquiv_append_coord (n := n)) '' convexConeGeneratedEpigraph f) ⊆
        closure ((prodLinearEquiv_append_coord (n := n)) ''
          epigraph (Set.univ : Set (Fin n → Real)) k) := by
    have hsubset :
        (prodLinearEquiv_append_coord (n := n)) '' convexConeGeneratedEpigraph f ⊆
          (prodLinearEquiv_append_coord (n := n)) ''
            epigraph (Set.univ : Set (Fin n → Real)) k := by
      intro y hy
      rcases hy with ⟨p, hp, rfl⟩
      exact ⟨p, hcone_subset hp, rfl⟩
    exact closure_mono hsubset
  have hclosure_union'' :
      closure (convexConeGeneratedEpigraph f) =
        (⋃ (lam : Real) (_ : 0 < lam),
          epigraph (Set.univ : Set (Fin n → Real)) (rightScalarMultiple f lam)) ∪
        epigraph (Set.univ : Set (Fin n → Real)) f0_plus := by
    exact
      closure_convexConeGeneratedEpigraph_eq_union
        (n := n) (f := f) (f0_plus := f0_plus) hclosure_union'
  have hk_conv_ne :
      ConvexFunctionOn (Set.univ : Set (Fin n → Real)) k ∧
        Set.Nonempty (epigraph (Set.univ : Set (Fin n → Real)) k) := by
    rw [hk]
    exact (posHomGenerated_convex_and_nonempty (n := n) (f := f) hfconv)
  have hk_conv : ConvexFunctionOn (Set.univ : Set (Fin n → Real)) k := hk_conv_ne.1
  have hk_ne_epi : Set.Nonempty (epigraph (Set.univ : Set (Fin n → Real)) k) := hk_conv_ne.2
  -- The epigraph of `k` sits in the closed cone generated by the epigraph of `f`.
  have h_epi_subset :
      epigraph (Set.univ : Set (Fin n → Real)) k ⊆
        closure (convexConeGeneratedEpigraph f) := by
    intro p hp
    rcases p with ⟨x, μ⟩
    have hle : k x ≤ (μ : EReal) := (mem_epigraph_univ_iff (f := k)).1 hp
    -- First handle the strict inequality case via the `sInf` formula.
    by_cases hlt : k x < (μ : EReal)
    · set S0 : Set EReal :=
        { z : EReal | ∃ lam : Real, 0 ≤ lam ∧ z = rightScalarMultiple f lam x }
      have hlt' : sInf S0 < (μ : EReal) := by
        simpa [hk_formula x, S0] using hlt
      rcases (sInf_lt_iff).1 hlt' with ⟨z, hzS0, hzlt⟩
      rcases hzS0 with ⟨lam, hlam, rfl⟩
      have hmem_union :
          (x, μ) ∈
              (⋃ (t : Real) (_ : 0 < t),
                epigraph (Set.univ : Set (Fin n → Real)) (rightScalarMultiple f t)) ∪
                epigraph (Set.univ : Set (Fin n → Real)) f0_plus := by
        by_cases hpos : 0 < lam
        · have hle' : rightScalarMultiple f lam x ≤ (μ : EReal) :=
            le_of_lt hzlt
          have hmem :
              (x, μ) ∈ epigraph (Set.univ : Set (Fin n → Real))
                (rightScalarMultiple f lam) :=
            (mem_epigraph_univ_iff (f := rightScalarMultiple f lam)).2 hle'
          refine Or.inl ?_
          refine Set.mem_iUnion.2 ⟨lam, ?_⟩
          refine Set.mem_iUnion.2 ⟨hpos, ?_⟩
          exact hmem
        · have hlam0 : lam = 0 := le_antisymm (le_of_not_gt hpos) hlam
          subst hlam0
          have hne_epi :
              Set.Nonempty (epigraph (Set.univ : Set (Fin n → Real)) f) := hfproper.2.1
          have hval :=
            rightScalarMultiple_zero_eval (f := f) hne_epi x
          by_cases hx0 : x = 0
          · subst hx0
            have hμpos : (0 : EReal) < (μ : EReal) := by
              simpa [hval] using hzlt
            have hzero :
                ((0 : Fin n → Real), (0 : Real)) ∈
                  epigraph (Set.univ : Set (Fin n → Real)) f0_plus := by
              have h0mem :
                  (0 : (Fin n → Real) × Real) ∈
                    Set.recessionCone
                      (epigraph (Set.univ : Set (Fin n → Real)) f) := by
                intro y hy t ht
                simpa using hy
              simpa [hrec] using h0mem
            have hle0 :
                f0_plus (0 : Fin n → Real) ≤ (0 : EReal) :=
              (mem_epigraph_univ_iff (f := f0_plus)).1 hzero
            have hleμ : f0_plus (0 : Fin n → Real) ≤ (μ : EReal) :=
              le_trans hle0 (le_of_lt hμpos)
            have hmem :
                ((0 : Fin n → Real), μ) ∈
                  epigraph (Set.univ : Set (Fin n → Real)) f0_plus :=
              (mem_epigraph_univ_iff (f := f0_plus)).2 hleμ
            exact Or.inr hmem
          · have htop := hval
            simp [hx0] at htop
            have hnot : ¬ rightScalarMultiple f 0 x < (μ : EReal) := by
              simp [htop]
            exact (hnot hzlt).elim
      have hmem_closure :
          (x, μ) ∈ closure (convexConeGeneratedEpigraph f) := by
        rw [hclosure_union'']
        exact hmem_union
      exact hmem_closure
    · -- Equality case: approximate by a decreasing sequence from above.
      have hEq : k x = (μ : EReal) := by
        exact le_antisymm hle (not_lt.mp hlt)
      have hclosed : IsClosed (closure (convexConeGeneratedEpigraph f)) := isClosed_closure
      have hmem_seq :
          ∀ m : ℕ,
            (x, μ + (1 : Real) / (m + 1)) ∈ closure (convexConeGeneratedEpigraph f) := by
        intro m
        have hlt' :
            k x < ((μ + (1 : Real) / (m + 1) : Real) : EReal) := by
          have hpos :
              (0 : Real) < (1 : Real) / (m + 1) := by
            have : 0 < (m + 1 : Real) := by
              exact_mod_cast (Nat.succ_pos m)
            exact one_div_pos.mpr this
          have hpos' : (μ : EReal) < ((μ + (1 : Real) / (m + 1) : Real) : EReal) := by
            have hpos'' : (μ : Real) < μ + (1 : Real) / (m + 1) := by linarith
            exact (EReal.coe_lt_coe_iff).2 hpos''
          simpa [hEq] using hpos'
        have hmem' : (x, μ + (1 : Real) / (m + 1)) ∈
            closure (convexConeGeneratedEpigraph f) := by
          -- apply the strict case to `μ + 1/(n+1)`
          have hle' :
              k x ≤ ((μ + (1 : Real) / (m + 1) : Real) : EReal) :=
            le_of_lt hlt'
          have hmem_epi :
              (x, μ + (1 : Real) / (m + 1)) ∈
                epigraph (Set.univ : Set (Fin n → Real)) k :=
            (mem_epigraph_univ_iff (f := k)).2 hle'
          -- reuse the strict-case proof by calling it directly
          have hmem'' :
              (x, μ + (1 : Real) / (m + 1)) ∈
                closure (convexConeGeneratedEpigraph f) := by
              -- re-run the strict case using the same argument as above
              -- with `μ + 1/(n+1)` in place of `μ`.
              have : k x < ((μ + (1 : Real) / (m + 1) : Real) : EReal) := hlt'
              -- short-circuit by reusing the earlier branch
              -- (the proof above is not packaged as a lemma, so we redo a small part)
              set S0 : Set EReal :=
                { z : EReal | ∃ lam : Real, 0 ≤ lam ∧ z = rightScalarMultiple f lam x }
              have hlt'' : sInf S0 < ((μ + (1 : Real) / (m + 1) : Real) : EReal) := by
                simpa [hk_formula x, S0] using hlt'
              rcases (sInf_lt_iff).1 hlt'' with ⟨z, hzS0, hzlt⟩
              rcases hzS0 with ⟨lam, hlam, rfl⟩
              have hmem_union :
                  (x, μ + (1 : Real) / (m + 1)) ∈
                      (⋃ (t : Real) (_ : 0 < t),
                        epigraph (Set.univ : Set (Fin n → Real)) (rightScalarMultiple f t)) ∪
                        epigraph (Set.univ : Set (Fin n → Real)) f0_plus := by
                by_cases hpos : 0 < lam
                · have hle' :
                    rightScalarMultiple f lam x ≤
                      ((μ + (1 : Real) / (m + 1) : Real) : EReal) :=
                    le_of_lt hzlt
                  have hmem :
                      (x, μ + (1 : Real) / (m + 1)) ∈
                        epigraph (Set.univ : Set (Fin n → Real))
                          (rightScalarMultiple f lam) :=
                    (mem_epigraph_univ_iff (f := rightScalarMultiple f lam)).2 hle'
                  refine Or.inl ?_
                  refine Set.mem_iUnion.2 ⟨lam, ?_⟩
                  refine Set.mem_iUnion.2 ⟨hpos, ?_⟩
                  exact hmem
                · have hlam0 : lam = 0 := le_antisymm (le_of_not_gt hpos) hlam
                  subst hlam0
                  have hne_epi :
                      Set.Nonempty (epigraph (Set.univ : Set (Fin n → Real)) f) := hfproper.2.1
                  have hval :=
                    rightScalarMultiple_zero_eval (f := f) hne_epi x
                  by_cases hx0 : x = 0
                  · subst hx0
                    have hμpos :
                        (0 : EReal) <
                          ((μ + (1 : Real) / (m + 1) : Real) : EReal) := by
                      simpa [hval] using hzlt
                    have hzero :
                        ((0 : Fin n → Real), (0 : Real)) ∈
                          epigraph (Set.univ : Set (Fin n → Real)) f0_plus := by
                      have h0mem :
                          (0 : (Fin n → Real) × Real) ∈
                            Set.recessionCone
                              (epigraph (Set.univ : Set (Fin n → Real)) f) := by
                        intro y hy t ht
                        simpa using hy
                      simpa [hrec] using h0mem
                    have hle0 :
                        f0_plus (0 : Fin n → Real) ≤ (0 : EReal) :=
                      (mem_epigraph_univ_iff (f := f0_plus)).1 hzero
                    have hleμ :
                        f0_plus (0 : Fin n → Real) ≤
                          ((μ + (1 : Real) / (m + 1) : Real) : EReal) :=
                      le_trans hle0 (le_of_lt hμpos)
                    have hmem :
                        ((0 : Fin n → Real), μ + (1 : Real) / (m + 1)) ∈
                          epigraph (Set.univ : Set (Fin n → Real)) f0_plus :=
                      (mem_epigraph_univ_iff (f := f0_plus)).2 hleμ
                    exact Or.inr hmem
                  · have htop := hval
                    simp [hx0] at htop
                    have : ¬ (rightScalarMultiple f 0 x) <
                        ((μ + (1 : Real) / (m + 1) : Real) : EReal) := by
                      simp [htop]
                    exact (this hzlt).elim
              simpa [hclosure_union''] using hmem_union
          exact hmem''
        exact hmem'
      have hlim :
          Filter.Tendsto
            (fun n : ℕ => (x, μ + (1 : Real) / (n + 1))) Filter.atTop (𝓝 (x, μ)) := by
        have h1 :
            Filter.Tendsto (fun _ : ℕ => x) Filter.atTop (𝓝 x) :=
          tendsto_const_nhds
        have h2' :
            Filter.Tendsto (fun n : ℕ => (1 : Real) / (n + 1)) Filter.atTop
              (𝓝 (0 : Real)) :=
          tendsto_one_div_add_atTop_nhds_zero_nat
        have h2 :
            Filter.Tendsto
              (fun n : ℕ => μ + (1 : Real) / (n + 1)) Filter.atTop (𝓝 μ) := by
          simpa using (tendsto_const_nhds.add h2')
        exact Filter.Tendsto.prodMk_nhds h1 h2
      exact hclosed.mem_of_tendsto hlim (eventually_of_forall hmem_seq)
  have hkproper : ProperConvexFunctionOn (Set.univ : Set (Fin n → Real)) k := by
    refine ⟨hk_conv, hk_ne_epi, ?_⟩
    intro x hx hbot
    -- Use the closed cone description to rule out `k x = ⊥`.
    have hxbot : k x = (⊥ : EReal) := hbot
    have hmem_epi : (x, (-1 : Real)) ∈ epigraph (Set.univ : Set (Fin n → Real)) k := by
      have hle : k x ≤ ((-1 : Real) : EReal) := by
        simp [hxbot]
      exact (mem_epigraph_univ_iff (f := k)).2 hle
    have hmem_closure : (x, (-1 : Real)) ∈ closure (convexConeGeneratedEpigraph f) :=
      h_epi_subset hmem_epi
    -- Scaling the vertical line gives a negative vertical at the origin.
    have hmem_union :
        (x, (-1 : Real)) ∈
            (⋃ (t : Real) (_ : 0 < t),
              epigraph (Set.univ : Set (Fin n → Real)) (rightScalarMultiple f t)) ∪
            epigraph (Set.univ : Set (Fin n → Real)) f0_plus := by
      rw [hclosure_union''] at hmem_closure
      exact hmem_closure
    have hclosed_union :
        IsClosed
          ((⋃ (t : Real) (_ : 0 < t),
            epigraph (Set.univ : Set (Fin n → Real)) (rightScalarMultiple f t)) ∪
            epigraph (Set.univ : Set (Fin n → Real)) f0_plus) := by
      simpa [hclosure_union''] using
        (isClosed_closure (s := convexConeGeneratedEpigraph f))
    -- For any `t > 0`, the point `(t • x, -1)` lies in the union.
    have hmem_scaled :
        ∀ t : Real, 0 < t →
          (t • x, (-1 : Real)) ∈
            (⋃ (s : Real) (_ : 0 < s),
              epigraph (Set.univ : Set (Fin n → Real)) (rightScalarMultiple f s)) ∪
            epigraph (Set.univ : Set (Fin n → Real)) f0_plus := by
      intro t ht
      -- the union is a cone, so scale `(x, -1/t)`
      have hmem_vert :
          (x, (-1 : Real) / t) ∈
            (⋃ (s : Real) (_ : 0 < s),
              epigraph (Set.univ : Set (Fin n → Real)) (rightScalarMultiple f s)) ∪
            epigraph (Set.univ : Set (Fin n → Real)) f0_plus := by
        have hle : k x ≤ ((-1 : Real) / t : EReal) := by
          have hbot' : k x = (⊥ : EReal) := hxbot
          simp [hbot']
        have hmem_epi :
            (x, (-1 : Real) / t) ∈ epigraph (Set.univ : Set (Fin n → Real)) k :=
          (mem_epigraph_univ_iff (f := k)).2 hle
        have hmem_closure' := h_epi_subset hmem_epi
        rw [hclosure_union''] at hmem_closure'
        exact hmem_closure'
      -- scale within the union
      rcases hmem_vert with hmem_vert | hmem_vert
      · rcases (Set.mem_iUnion).1 hmem_vert with ⟨s, hmem_vert⟩
        rcases (Set.mem_iUnion).1 hmem_vert with ⟨hspos, hmem_vert⟩
        have hle' :
            rightScalarMultiple f s x ≤ ((-1 : Real) / t : EReal) :=
          (mem_epigraph_univ_iff (f := rightScalarMultiple f s)).1 hmem_vert
        have hle'' :
            rightScalarMultiple f (t * s) (t • x) ≤ ((-1 : Real) : EReal) := by
          -- scale the inequality
          have hmul :=
            ereal_mul_le_mul_of_pos_left_general (t := t) (ht := ht) hle'
          have hright :
              ((t : Real) : EReal) * ((-1 : Real) / t : EReal) = (-1 : EReal) := by
            have hdiv : ((-1 : Real) / t : EReal) = (t⁻¹ : EReal) * (-1 : EReal) := by
              simp [div_eq_mul_inv, mul_comm]
            calc
              (t : EReal) * ((-1 : Real) / t : EReal) =
                  (t : EReal) * ((t⁻¹ : EReal) * (-1 : EReal)) := by
                    rw [hdiv]
              _ = (-1 : EReal) := by
                    simpa using
                      (ereal_mul_inv_smul (t := t) (ht := ht) (x := (-1 : EReal)))
          have hmul' :
              ((t : Real) : EReal) * rightScalarMultiple f s x ≤ ((-1 : Real) : EReal) := by
            calc
              ((t : Real) : EReal) * rightScalarMultiple f s x ≤
                  ((t : Real) : EReal) * ((-1 : Real) / t : EReal) := hmul
              _ = (-1 : EReal) := hright
          have hspos' : 0 < t * s := mul_pos ht hspos
          have hpos_ts :=
            rightScalarMultiple_pos (f := f) (lam := t * s) hfconv hspos' (t • x)
          have hpos_s :=
            rightScalarMultiple_pos (f := f) (lam := s) hfconv hspos x
          have hsmul : (t * s)⁻¹ • (t • x) = s⁻¹ • x := by
            have ht0 : t ≠ 0 := ne_of_gt ht
            have hs0 : s ≠ 0 := ne_of_gt hspos
            have hscale : (t * s)⁻¹ * t = s⁻¹ := by
              field_simp [ht0, hs0]
            calc
              (t * s)⁻¹ • (t • x) = ((t * s)⁻¹ * t) • x := by
                rw [smul_smul]
              _ = s⁻¹ • x := by
                rw [hscale]
          have hsmul' : (s⁻¹ * t⁻¹) • t • x = s⁻¹ • x := by
            have ht0 : t ≠ 0 := ne_of_gt ht
            calc
              (s⁻¹ * t⁻¹) • t • x = ((s⁻¹ * t⁻¹) * t) • x := by
                rw [smul_smul]
              _ = s⁻¹ • x := by
                simp [ht0]
          have hmul1 :
              ((t * s : Real) : EReal) * f (s⁻¹ • x) ≤ ((-1 : Real) : EReal) := by
            have hmul1' :
                ((t : EReal) * ((s : EReal) * f (s⁻¹ • x))) ≤ ((-1 : Real) : EReal) := by
              simpa [hpos_s, mul_assoc] using hmul'
            simpa [mul_comm, mul_left_comm, mul_assoc, EReal.coe_mul] using hmul1'
          have hmul2 :
