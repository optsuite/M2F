    (hnorm :
      (Finset.sum (Finset.univ.filter (fun i : Fin m => (i : ℕ) < k))
        (fun i => lam i)) = 1)
    (hnonneg : ∀ i, 0 ≤ lam i) :
    (∀ j, (∑ i, lam i * a i j) = x j) ∧
      (Finset.sum (Finset.univ.filter (fun i : Fin m => (i : ℕ) < k))
        (fun i => lam i)) = 1 ∧
      (∀ i, 0 ≤ lam i) := by
  exact ⟨hlin, hnorm, hnonneg⟩

